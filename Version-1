# ### Expert E — Qwen2-VL (Premium Fallback) [P13]

# %%

class ExpertE_QwenVL(OCRExpert):
    expert_id = ExpertID.E

    def __init__(self):
        self._model = None
        self._processor = None

    def load(self):
        if self._loaded:
            return
        from transformers import AutoProcessor, Qwen2VLForConditionalGeneration
        from transformers import BitsAndBytesConfig

        logger.info("Loading Expert E (Qwen2-VL): %s → %s (4-bit)",
                     config.QWEN_VL_MODEL, config.DEVICE_HEAVY)
        self._processor = AutoProcessor.from_pretrained(config.QWEN_VL_MODEL)
        qconfig = BitsAndBytesConfig(load_in_4bit=True)
        self._model = Qwen2VLForConditionalGeneration.from_pretrained(
            config.QWEN_VL_MODEL,
            device_map=config.DEVICE_HEAVY,
            quantization_config=qconfig,
        )
        self._model.eval()
        self._loaded = True
        logger.info("✓ Expert E loaded (4-bit on %s)", config.DEVICE_HEAVY)

    def unload(self):
        if self._model is not None and not config.CO_RESIDENT:
            import gc
            del self._model
            del self._processor
            self._model = None
            self._processor = None
            gc.collect()
            torch.cuda.empty_cache()
        self._loaded = False

    def recognize(self, crop: np.ndarray, bbox: BoundingBox) -> ExpertOutput:
        t0 = time.perf_counter()
        self.load()

        h, w = crop.shape[:2]
        max_edge = max(h, w)

        # FIX-13: Size gate — tiny regions (<100px) don't justify Expert E latency.
        # Fall back to Expert B (PaddleOCR/Tesseract) immediately.
        if max_edge < 100:
            logger.info("    ↳ Expert E: region too small (%dx%d) — falling back to Expert B", w, h)
            fb = ExpertB_PaddleOCR()
            fb.load()
            return fb.recognize(crop, bbox)

        if max_edge > 1024:
            scale = 1024 / max_edge
            crop = cv2.resize(crop, (int(w * scale), int(h * scale)),
                              interpolation=cv2.INTER_AREA)
        # FIX-13: Only upscale genuinely tiny images (<200px), not <512px
        elif max_edge < 200:
            scale = 200 / max_edge
            crop = cv2.resize(crop, (int(w * scale), int(h * scale)),
                              interpolation=cv2.INTER_CUBIC)

        pil = self._to_pil(crop)
        prompt = (
            "You are a medical document transcription expert. "
            "Transcribe the text in this image EXACTLY as written. "
            "Preserve all medical dosages, abbreviations, units, and formatting. "
            "Do not interpret, summarise, or hallucinate extra text. "
            "Stop generating when you reach the end of the text in the image. "
            "Do not output spatial coordinates or bounding boxes."
        )
        messages = [{"role": "user", "content": [
            {"type": "image"}, {"type": "text", "text": prompt}
        ]}]
        text_prompt = self._processor.apply_chat_template(
            messages, tokenize=False, add_generation_prompt=True)
        inputs = self._processor(
            text=[text_prompt], images=[pil],
            return_tensors="pt", padding=True,
        ).to(self._model.device)

        from transformers import GenerationConfig
        _gen_cfg = GenerationConfig(
            max_new_tokens=2048,
            do_sample=False,
            repetition_penalty=1.1,
        )
        with torch.no_grad():
            out = self._model.generate(**inputs, generation_config=_gen_cfg)
        generated = out[0][inputs["input_ids"].shape[1]:]
        text = self._processor.decode(generated, skip_special_tokens=True).strip()

        import re as _re
        text = _re.sub(r'<ref>[^<]*</ref>', '', text)
        text = _re.sub(r'<box>[^<]*</box>', '', text)
        text = _re.sub(
            r'\(\s*\d{1,4}\s*,\s*\d{1,4}\s*\)'
            r'\s*,?\s*'
            r'\(\s*\d{1,4}\s*,\s*\d{1,4}\s*\)',
            '', text)
        text = _re.sub(r'\s{2,}', ' ', text).strip()

        # FIX-2: Estimate confidence from output text instead of hardcoding 0.85.
        # Qwen2-VL does not return per-token logprobs in this generation config.
        if not text.strip():
            conf = 0.0
        else:
            _hallucination_markers = _re.search(
                r'\[INST\]|<\|im_start\|>|<\|im_end\|>|\(\d+,\d+\).*\(\d+,\d+\)',
                text)
            if _hallucination_markers:
                conf = 0.1
            else:
                # Over-generation check: estimate expected words from image size
                _est_words = max(1, (h * w) / 5000)  # rough: 5000 px² per word
                _actual_words = len(text.split())
                if _actual_words > 3 * _est_words:
                    conf = 0.3  # over-generation flag
                else:
                    conf = 0.82

        elapsed = (time.perf_counter() - t0) * 1000
        return ExpertOutput(
            raw_text=text,
            word_tokens=self._text_to_word_tokens(text, self.expert_id, conf, bbox),
            char_confidence_mean=conf,
            word_confidence_mean=conf,
            expert_id=self.expert_id,
            inference_time_ms=elapsed,
        )

print("✓ Expert E (Qwen2-VL) defined")

