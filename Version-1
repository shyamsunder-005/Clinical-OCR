def detect_script(text: str) -> bool:
    if not text:
        return False
    non_latin = sum(1 for c in text if ord(c) > 0x024F and not c.isspace())
    total = sum(1 for c in text if not c.isspace())
    if total == 0:
        return False
    return (non_latin / total) > 0.20


def compute_routing_vector(
    region_crop: np.ndarray,
    region: RegionResult,
    page_quality_tier: QualityTier,
    page_region_classes: List[RegionClass],
    probe_text: str = "",
    probe_confidence: float = 0.0,
) -> RoutingVector:
    gray = cv2.cvtColor(region_crop, cv2.COLOR_BGR2GRAY) \
        if len(region_crop.shape) == 3 else region_crop

    lap_var, quality_tier = compute_laplacian_quality(region_crop)
    blur = compute_blur_score(gray)
    noise = estimate_noise(gray)
    script_flag = detect_script(probe_text)

    distinct_classes = len(set(page_region_classes))
    complexity = min(distinct_classes / 5.0, 1.0)

    predicted_cer = max(0.01, 0.30 - 0.29 * probe_confidence)

    return RoutingVector(
        laplacian_variance=lap_var,
        blur_score=blur,
        noise_estimate=noise,
        predicted_cer=predicted_cer,
        region_class=region.region_class,
        quality_tier=quality_tier,
        handwriting_score=region.metadata.get("handwriting_score", 0.0),
        script_flag=script_flag,
        complexity_score=complexity,
        probe_confidence=probe_confidence,
        # FIX 5: probe_text was computed and passed around but never stored on
        # the RoutingVector, so rv.probe_text in route_region() always raised
        # AttributeError. Now stored alongside the other routing features.
        probe_text=probe_text,
    )

