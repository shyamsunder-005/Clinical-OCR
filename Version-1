def batch_process(input_folder: str, output_folder: str,
                   force_expert: Optional[ExpertID] = None) -> None:
    import glob, json
    os.makedirs(output_folder, exist_ok=True)

    files = []
    for ext in ["*.pdf", "*.png", "*.jpg", "*.jpeg", "*.tiff", "*.bmp"]:
        files.extend(glob.glob(os.path.join(input_folder, ext)))

    print(f"Found {len(files)} documents in {input_folder}")

    for file_path in files:
        filename = os.path.basename(file_path)
        print(f"\nProcessing {filename} …")
        try:
            result = pipeline.process_document(file_path, force_expert=force_expert)
            txt_path = os.path.join(output_folder, f"{filename}.txt")
            with open(txt_path, "w", encoding="utf-8") as f:
                f.write(get_plain_text(result))

            json_path = os.path.join(output_folder, f"{filename}.json")
            export_provenance_json(result, json_path)

            print(f"✓ {filename} — {result.processing_time_seconds}s")
        except Exception as e:
            print(f"❌ {filename} failed: {e}")

