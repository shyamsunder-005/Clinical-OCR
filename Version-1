# ## 4 · Stage 0 — Pre-processing & Quality Scoring [P1][P3][P4][P5]

# %%
import cv2
from pathlib import Path
from pdf2image import convert_from_path

# ── Ingestion ────────────────────────────────────────────────────────

def ingest_document(file_path: str) -> List[np.ndarray]:
    suffix = Path(file_path).suffix.lower()
    if suffix == ".pdf":
        logger.info("Rasterising PDF at %d DPI", config.DPI)
        pil_imgs = convert_from_path(file_path, dpi=config.DPI)
        return [cv2.cvtColor(np.array(img), cv2.COLOR_RGB2BGR) for img in pil_imgs]
    if suffix in {".png", ".jpg", ".jpeg", ".tiff", ".tif", ".bmp", ".webp"}:
        img = cv2.imread(file_path, cv2.IMREAD_COLOR)
        if img is None:
            raise ValueError(f"Failed to read image: {file_path}")
        return [img]
    raise ValueError(f"Unsupported format: {suffix}")


# ── Resize ───────────────────────────────────────────────────────────

def resize_preserving_aspect(image: np.ndarray,
                              max_dim: int = config.MAX_IMAGE_DIM) -> np.ndarray:
    h, w = image.shape[:2]
    if max(h, w) <= max_dim:
        return image
    scale = max_dim / max(h, w)
    return cv2.resize(image, (int(w * scale), int(h * scale)),
                      interpolation=cv2.INTER_AREA)


# ── Binarization [P3] ───────────────────────────────────────────────

def binarize_otsu(gray: np.ndarray) -> np.ndarray:
    _, binary = cv2.threshold(gray, 0, 255,
                              cv2.THRESH_BINARY + cv2.THRESH_OTSU)
    return binary

def binarize_sauvola(gray: np.ndarray, ws: int = config.SAUVOLA_WINDOW,
                      k: float = config.SAUVOLA_K) -> np.ndarray:
    gray_f = gray.astype(np.float64)
    mean = cv2.boxFilter(gray_f, -1, (ws, ws), normalize=True)
    # FIX-14: Numerically stable local variance — subtract mean before squaring
    # to avoid catastrophic cancellation when gray_f values are large.
    diff = gray_f - mean
    sq_mean = cv2.boxFilter(diff ** 2, -1, (ws, ws), normalize=True)
    std = np.sqrt(np.maximum(sq_mean, 0.0))
    threshold = mean * (1.0 + k * (std / 128.0 - 1.0))
    binary = np.zeros_like(gray)
    binary[gray >= threshold] = 255
    return binary

def auto_binarize(gray: np.ndarray) -> np.ndarray:
    h, w = gray.shape
    tile = min(h, w, 64)
    if tile < 16:
        return binarize_otsu(gray)
    means = []
    for y in range(0, h - tile + 1, tile):
        for x in range(0, w - tile + 1, tile):
            means.append(float(np.mean(gray[y:y+tile, x:x+tile])))
    if float(np.var(means)) > 500.0:
        return binarize_sauvola(gray)
    return binarize_otsu(gray)


# ── Deskew [P3] ─────────────────────────────────────────────────────

def deskew(image: np.ndarray) -> np.ndarray:
    coords = np.column_stack(np.where(image < 128))
    if len(coords) < 100:
        return image
    angle = cv2.minAreaRect(coords)[-1]
    angle = -(90 + angle) if angle < -45 else -angle
    if abs(angle) < 0.5 or abs(angle) > 15:
        return image
    h, w = image.shape[:2]
    M = cv2.getRotationMatrix2D((w // 2, h // 2), angle, 1.0)
    return cv2.warpAffine(image, M, (w, h), flags=cv2.INTER_CUBIC,
                          borderMode=cv2.BORDER_REPLICATE)


# ── CLAHE Enhancement [P3] ──────────────────────────────────────────

def enhance_clahe(crop: np.ndarray) -> np.ndarray:
    gray = cv2.cvtColor(crop, cv2.COLOR_BGR2GRAY) if len(crop.shape) == 3 else crop.copy()
    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8, 8))
    return clahe.apply(gray)


# ── Laplacian Quality Scorer [P1] ───────────────────────────────────

def compute_laplacian_quality(image: np.ndarray) -> tuple:
    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY) if len(image.shape) == 3 else image
    lap = cv2.Laplacian(gray, cv2.CV_64F)
    variance = float(lap.var())
    if variance >= config.QUALITY_HIGH:
        return variance, QualityTier.HIGH
    elif variance >= config.QUALITY_MEDIUM:
        return variance, QualityTier.MEDIUM
    else:
        return variance, QualityTier.LOW

def compute_blur_score(gray: np.ndarray) -> float:
    lap = cv2.Laplacian(gray, cv2.CV_64F)
    return float(np.mean(np.abs(lap)))

def estimate_noise(gray: np.ndarray) -> float:
    blur = cv2.GaussianBlur(gray, (5, 5), 0)
    residual = gray.astype(np.float64) - blur.astype(np.float64)
    return float(np.std(residual))


# FIX-5: Replaced Tesseract OSD with lightweight projection-profile orientation
# estimator. 10× faster and more reliable on small crops. For 90° rotated crops
# (common for patient ID stickers), tries both directions and probes each.
def detect_and_correct_rotation(crop: np.ndarray) -> tuple:
    gray = cv2.cvtColor(crop, cv2.COLOR_BGR2GRAY) if len(crop.shape) == 3 else crop
    h, w = gray.shape[:2]
    if h < 20 or w < 20:
        return crop, 0

    # Compute horizontal vs vertical projection energy
    _, binary = cv2.threshold(gray, 0, 255, cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU)
    h_proj = np.sum(binary, axis=1).astype(float)
    v_proj = np.sum(binary, axis=0).astype(float)

    h_energy = float(np.var(h_proj)) if len(h_proj) > 1 else 0.0
    v_energy = float(np.var(v_proj)) if len(v_proj) > 1 else 0.0

    # Normal text: high horizontal energy (text lines create peaks in row projection)
    # 90° rotated text: high vertical energy
    if v_energy > h_energy * 2.0 and v_energy > 1000:
        # Likely 90° rotated — try both directions, pick best via fast OCR probe
        import pytesseract
        cw  = cv2.rotate(crop, cv2.ROTATE_90_CLOCKWISE)
        ccw = cv2.rotate(crop, cv2.ROTATE_90_COUNTERCLOCKWISE)

        def _quick_probe(img):
            try:
                data = pytesseract.image_to_data(
                    img, config="--oem 3 --psm 6",
                    output_type=pytesseract.Output.DICT)
                chars = sum(len(w) for w, c in zip(data["text"], data["conf"])
                            if w.strip() and int(c) > 0)
                conf  = np.mean([int(c)/100.0 for c in data["conf"]
                                 if int(c) > 0]) if any(int(c) > 0 for c in data["conf"]) else 0.0
                return chars * conf
            except Exception:
                return 0.0

        score_cw  = _quick_probe(cw)
        score_ccw = _quick_probe(ccw)

        if score_cw >= score_ccw and score_cw > 0:
            logger.info("    ↳ Rotation corrected: 90° CW (projection-profile)")
            return cw, 90
        elif score_ccw > 0:
            logger.info("    ↳ Rotation corrected: 270° CW (projection-profile)")
            return ccw, 270

    # Check for 180° rotation: text exists but ascenders/descenders are inverted
    # This is rare and hard to detect reliably; skip unless energy is very low
    return crop, 0

# ── Full Stage 0 Pipeline ───────────────────────────────────────────

def preprocess_page(image: np.ndarray) -> tuple:
    resized = resize_preserving_aspect(image)
    gray = cv2.cvtColor(resized, cv2.COLOR_BGR2GRAY) if len(resized.shape) == 3 else resized
    binary = auto_binarize(gray)
    binary = deskew(binary)
    variance, tier = compute_laplacian_quality(image)
    logger.info("Stage 0: page quality = %.1f (%s)", variance, tier.value)
    return binary, variance, tier

print("✓ Stage 0 — Pre-processing ready")

