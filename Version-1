import matplotlib.pyplot as plt
import matplotlib.patches as patches


def visualize_layout(image: np.ndarray, regions: List[RegionResult],
                      page_num: int = 1) -> None:
    img_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)

    colors = {
        "HANDWRITING":    "#FF4444",
        "PRINTED_TEXT":   "#4488FF",
        "TABLE":          "#44CC44",
        "FIGURE":         "#FF8800",
        "FORM_FIELD":     "#AA44FF",
        "STAMP":          "#FFAA00",
        "SIGNATURE":      "#FF44AA",
        "VISUAL_ELEMENT": "#888888",
    }

    fig, ax = plt.subplots(1, figsize=(12, 14))
    ax.imshow(img_rgb)

    for r in regions:
        bb = r.bbox
        color = colors.get(r.region_class.value, "#CCCCCC")
        rect = patches.Rectangle(
            (bb.x, bb.y), bb.w, bb.h,
            linewidth=2, edgecolor=color, facecolor="none")
        ax.add_patch(rect)

        expert = r.expert_id.value if r.expert_id else "?"
        label = f"{r.region_class.value} → Expert {expert} ({r.detection_confidence:.2f})"
        ax.text(bb.x, max(0, bb.y - 5), label, color="white", fontsize=8,
                bbox=dict(facecolor=color, alpha=0.85, edgecolor="none", pad=1))

    plt.axis("off")
    plt.title(f"Page {page_num} — Layout + Expert Routing", fontsize=14)
    plt.tight_layout()
    plt.show()


def visualize_quality(result: DocumentExtractionResult) -> None:
    for page in result.pages:
        qr = page.quality_report
        if not qr:
            continue
        print(f"\n{'─' * 50}")
        print(f"  Page {page.page_number} Quality Report")
        print(f"{'─' * 50}")
        print(f"  Quality tier     : {qr.page_quality_tier.value} (var={qr.page_laplacian_variance:.0f})")
        print(f"  Regions          : {qr.total_regions}")
        print(f"  % Handwritten    : {qr.pct_handwritten:.0%}")
        print(f"  % Printed        : {qr.pct_printed:.0%}")
        print(f"  % Low confidence : {qr.pct_low_confidence:.0%}")

        expert_counts: Dict[str, int] = {}
        for entry in page.routing_log:
            for eid in entry.experts_invoked:
                expert_counts[eid.value] = expert_counts.get(eid.value, 0) + 1
        print(f"  Expert usage     : {expert_counts}")

        if page.routing_log:
            avg_k = sum(len(e.experts_invoked) for e in page.routing_log) / len(page.routing_log)
            print(f"  Avg experts/region: {avg_k:.2f}")


def display_results(result: DocumentExtractionResult) -> None:
    print(f"\n{'═' * 60}")
    print(f"  RESULTS: {result.filename}")
    print(f"  Doc ID: {result.document_id}")
    print(f"  Pages: {result.total_pages}  |  Time: {result.processing_time_seconds}s")
    print(f"{'═' * 60}")

