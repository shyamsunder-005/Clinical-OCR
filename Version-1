# ── Table Structure Detection ─────────────────────────────────────────

def has_table_structure(page_image: np.ndarray) -> bool:
    gray = cv2.cvtColor(page_image, cv2.COLOR_BGR2GRAY) if len(page_image.shape) == 3 else page_image
    edges = cv2.Canny(gray, 50, 150, apertureSize=3)
    # FIX-4: Lowered HoughLinesP parameters for clinical form line detection.
    # threshold=100 (was 200) — clinical forms have thinner lines
    # minLineLength=shape[1]//6 (was //3) — catch shorter internal cell lines
    # maxLineGap=20 (was 10) — allow small gaps in dashed/partial lines
    lines = cv2.HoughLinesP(
        edges, 1, np.pi / 180, threshold=100,
        minLineLength=page_image.shape[1] // 6, maxLineGap=20,
    )
    if lines is None:
        return False
    horizontal = sum(1 for l in lines for x1, y1, x2, y2 in [l[0]] if abs(y1 - y2) < 5)
    vertical   = sum(1 for l in lines for x1, y1, x2, y2 in [l[0]] if abs(x1 - x2) < 5)
    # FIX-4: Require at least 3 horizontal AND 1 vertical (or vice versa)
    return (horizontal >= 3 and vertical >= 1) or (vertical >= 3 and horizontal >= 1)

def grid_aware_split(page_image: np.ndarray,
                      parent_region: "RegionResult") -> List["RegionResult"]:
    gray = cv2.cvtColor(page_image, cv2.COLOR_BGR2GRAY) if len(page_image.shape) == 3 else page_image
    h, w = gray.shape[:2]
    parent_bb = parent_region.bbox

    edges = cv2.Canny(gray, 50, 150, apertureSize=3)
    # FIX-4: Same parameter fixes as has_table_structure()
    lines = cv2.HoughLinesP(edges, 1, np.pi / 180, threshold=100,
                             minLineLength=w // 6, maxLineGap=20)

    h_lines, v_lines = [], []
    if lines is not None:
        for l in lines:
            x1, y1, x2, y2 = l[0]
            if abs(y1 - y2) < 5:
                h_lines.append((y1 + y2) // 2)
            elif abs(x1 - x2) < 5:
                v_lines.append((x1 + x2) // 2)

    h_lines = sorted(set(h_lines))
    h_clustered: List[int] = []
    for y in h_lines:
        if not h_clustered or y - h_clustered[-1] > 15:
            h_clustered.append(y)

    v_lines = sorted(set(v_lines))
    v_clustered: List[int] = []
    for x in v_lines:
        if not v_clustered or x - v_clustered[-1] > 15:
            v_clustered.append(x)

    row_boundaries = sorted(set([0] + h_clustered + [h]))
    col_boundaries = sorted(set([0] + v_clustered + [w])) if len(v_clustered) >= 1 else [0, w]

    regions: List[RegionResult] = []
    min_cell_area = h * w * 0.005

    for r_idx in range(len(row_boundaries) - 1):
        y1, y2 = row_boundaries[r_idx], row_boundaries[r_idx + 1]
        if y2 - y1 < 10:
            continue
        for c_idx in range(len(col_boundaries) - 1):
            x1, x2 = col_boundaries[c_idx], col_boundaries[c_idx + 1]
            if x2 - x1 < 10:
                continue
            if (x2 - x1) * (y2 - y1) < min_cell_area:
                continue

            cell_crop = gray[y1:y2, x1:x2]
            ink = float(np.sum(cell_crop < 200)) / max(cell_crop.size, 1)
            if ink < 0.01:
                continue

            regions.append(RegionResult(
                region_class=parent_region.region_class,
                detection_confidence=parent_region.detection_confidence * 0.9,
                bbox=BoundingBox(
                    x=parent_bb.x + x1, y=parent_bb.y + y1,
                    w=x2 - x1, h=y2 - y1,
                ),
                metadata={"detection_method": "grid_aware_split"},
            ))

    return regions if regions else [parent_region]


class LayoutDetector:
    """
    Stage 1: DocLayout-YOLO [P7] + handwriting heuristic classifier.
    Falls back to contour-based detection if YOLO unavailable.
    """

    def __init__(self):
        self._model = None
        self._load_model()

    def _load_model(self):
        local_dir = Path(config.DLA_LOCAL_DIR)
        local_dir.mkdir(parents=True, exist_ok=True)
        local_path = local_dir / "doclayout_yolo.pt"

        if local_path.is_file():
            self._init_yolo(str(local_path))
            return

        try:
            from huggingface_hub import hf_hub_download
            logger.info("Downloading DocLayout-YOLO from HuggingFace Hub …")
            path = hf_hub_download(
                repo_id=config.DLA_MODEL_REPO,
                filename=config.DLA_MODEL_FILE,
                local_dir=str(local_dir),
            )
            self._init_yolo(path)
        except Exception as e:
            logger.warning("DLA download failed (%s). Using contour fallback.", e)

    def _init_yolo(self, path: str):
        try:
            from ultralytics import YOLO
            self._model = YOLO(path)
            self._model.to("cpu")
            logger.info("DocLayout-YOLO loaded: %s", path)

            # Patch DocLayout-YOLO bn attribute bug
            try:
                import torch.nn.functional as F
                import doclayout_yolo.nn.modules.g2l_crm as g2l
                def patched_dilated_conv(self_m, x, dilation):
                    weight = self_m.dcv.conv.weight
                    padding = dilation * (self_m.k // 2)
                    x = F.conv2d(x, weight, stride=1, padding=padding, dilation=dilation)
                    if hasattr(self_m.dcv, "bn") and self_m.dcv.bn is not None:
                        x = self_m.dcv.bn(x)
                    if hasattr(self_m.dcv, "act") and self_m.dcv.act is not None:
                        x = self_m.dcv.act(x)
                    return x
                for name in dir(g2l):
                    obj = getattr(g2l, name)
                    if isinstance(obj, type) and hasattr(obj, "dilated_conv"):
                        obj.dilated_conv = patched_dilated_conv
            except Exception:
                pass

            # Patch Ultralytics postprocess for DocLayout-YOLO dict output
            try:
                from ultralytics.models.yolo.detect.predict import DetectionPredictor
                if not hasattr(DetectionPredictor, "_orig_pp"):
                    DetectionPredictor._orig_pp = DetectionPredictor.postprocess
                    def patched_pp(self_p, preds, img, orig_imgs):
                        if isinstance(preds, dict):
                            preds = preds.get("one2one", list(preds.values())[0])
                            if isinstance(preds, (list, tuple)):
                                preds = preds[0]
                        return self_p._orig_pp(preds, img, orig_imgs)
                    DetectionPredictor.postprocess = patched_pp
            except Exception:
                pass

        except Exception as e:
            logger.warning("YOLO init failed (%s). Contour fallback.", e)
            self._model = None

    # ── Detection ────────────────────────────────────────────────────

    def detect(self, original: np.ndarray,
               preprocessed: np.ndarray) -> List[RegionResult]:
        if self._model is not None:
            regions = self._detect_yolo(original)
        else:
            regions = self._detect_contours(preprocessed, original)

        page_h, page_w = original.shape[:2]
        page_area = page_h * page_w
        if len(regions) == 1:
            r = regions[0]
            region_area = r.bbox.w * r.bbox.h
            if region_area > config.FULL_PAGE_AREA_THRESHOLD * page_area:
                if has_table_structure(original):
                    logger.info("    ↳ Full-page region with table structure detected. Splitting...")
                    regions = grid_aware_split(original, r)

        for region in regions:
            if region.region_class == RegionClass.PRINTED_TEXT:
                crop = self._get_crop(original, region.bbox)
                if crop.size == 0:
                    continue
                hw_score = self._classify_handwriting(crop)
                region.metadata["handwriting_score"] = round(hw_score, 3)
                if hw_score > config.HANDWRITING_THRESHOLD:
                    region.region_class = RegionClass.HANDWRITING

        regions = self._sort_reading_order(regions)
        return regions

    def _detect_yolo(self, image: np.ndarray) -> List[RegionResult]:
        try:
            self._model.to(config.DEVICE_LAYOUT)
            results = self._model(image, conf=config.DLA_CONFIDENCE, verbose=False)
        finally:
            if not config.CO_RESIDENT:
                self._model.to("cpu")
                torch.cuda.empty_cache()

        regions = []
        h_img, w_img = image.shape[:2]
        for result in results:
            for box in result.boxes:
                cls_id = int(box.cls[0])
                cls = DOCLAYNET_CLASS_MAP.get(cls_id, RegionClass.PRINTED_TEXT)
                x1, y1, x2, y2 = box.xyxy[0].cpu().numpy().astype(int)

                pad_x = max(15, int(w_img * 0.015))
                pad_y = max(10, int(h_img * 0.010))
                x1 = max(0, x1 - pad_x)
                y1 = max(0, y1 - pad_y)
                x2 = min(w_img, x2 + pad_x)
                y2 = min(h_img, y2 + pad_y)

                regions.append(RegionResult(
                    region_class=cls,
                    detection_confidence=float(box.conf[0]),
                    bbox=BoundingBox(x=int(x1), y=int(y1),
                                     w=int(x2 - x1), h=int(y2 - y1)),
                    metadata={"detection_method": "doclayout_yolo"},
                ))
        return regions if regions else self._whole_page(image)

    def _detect_contours(self, preprocessed: np.ndarray,
                          original: np.ndarray) -> List[RegionResult]:
        inverted = cv2.bitwise_not(preprocessed)
        kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (30, 10))
        dilated = cv2.dilate(inverted, kernel, iterations=2)
        contours, _ = cv2.findContours(dilated, cv2.RETR_EXTERNAL,
                                        cv2.CHAIN_APPROX_SIMPLE)
        h, w = original.shape[:2]
        min_area = (h * w) * 0.001
        pad = 5
        regions = []
        for c in contours:
            x, y, cw, ch = cv2.boundingRect(c)
            if cw * ch < min_area:
                continue
            regions.append(RegionResult(
                region_class=RegionClass.PRINTED_TEXT,
                detection_confidence=0.85,
                bbox=BoundingBox(x=max(0, x - pad), y=max(0, y - pad),
                                 w=min(cw + 2*pad, w - x), h=min(ch + 2*pad, h - y)),
                metadata={"detection_method": "contour_fallback"},
            ))
        return regions if regions else self._whole_page(original)

    # ── Handwriting Classifier (4-feature heuristic) ─────────────────

    def _classify_handwriting(self, crop: np.ndarray) -> float:
        gray = cv2.cvtColor(crop, cv2.COLOR_BGR2GRAY) if len(crop.shape) == 3 else crop.copy()
        _, binary = cv2.threshold(gray, 0, 255,
                                  cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU)
        try:
            f1 = self._feat_cc_variance(binary)
            f2 = self._feat_stroke_width(binary)
            f3 = self._feat_baseline(binary)
            f4 = self._feat_edge_entropy(gray)
        except Exception:
            return 0.0
        return float(np.clip(0.30*f1 + 0.25*f2 + 0.25*f3 + 0.20*f4, 0, 1))

    @staticmethod
    def _feat_cc_variance(binary: np.ndarray) -> float:
        n, _, stats, _ = cv2.connectedComponentsWithStats(binary, 8)
        if n <= 2:
            return 0.0
        areas = stats[1:, cv2.CC_STAT_AREA].astype(float)
        areas = areas[areas > 20]
        if len(areas) < 3:
            return 0.0
        cv_val = float(np.std(areas) / (np.mean(areas) + 1e-6))
        return float(1 / (1 + np.exp(-(cv_val - 1.5) / 0.8)))

    @staticmethod
    def _feat_stroke_width(binary: np.ndarray) -> float:
        dist = cv2.distanceTransform(binary, cv2.DIST_L2, 5)
        vals = dist[dist > 0]
        if len(vals) < 10:
            return 0.0
        swv = float(np.std(vals) / (np.mean(vals) + 1e-6))
        return float(1 / (1 + np.exp(-(swv - 0.5) / 0.3)))

    @staticmethod
    def _feat_baseline(binary: np.ndarray) -> float:
        proj = np.sum(binary, axis=1).astype(float)
        if proj.max() < 1:
            return 0.0
        ks = max(3, len(proj) // 50)
        if ks % 2 == 0:
            ks += 1
        sm = cv2.GaussianBlur(proj.reshape(-1, 1), (1, ks), 0).flatten()
        diff = np.diff((sm > sm.max() * 0.2).astype(np.int8))
        starts = np.where(diff == 1)[0]
        if len(starts) < 3:
            return 0.0
        sp = np.diff(starts).astype(float)
        cv_sp = float(np.std(sp) / (np.mean(sp) + 1e-6))
        return float(1 / (1 + np.exp(-(cv_sp - 0.4) / 0.25)))

    @staticmethod
    def _feat_edge_entropy(gray: np.ndarray) -> float:
        sx = cv2.Sobel(gray, cv2.CV_64F, 1, 0, ksize=3)
        sy = cv2.Sobel(gray, cv2.CV_64F, 0, 1, ksize=3)
        mag = np.sqrt(sx**2 + sy**2)
        angles = np.arctan2(sy, sx)
        mask = mag > (mag.max() * 0.1)
        if mask.sum() < 10:
            return 0.0
        hist, _ = np.histogram(angles[mask], bins=36, range=(-np.pi, np.pi))
        hist = hist.astype(float)
        hist /= hist.sum() + 1e-10
        entropy = float(-np.sum(hist * np.log2(hist + 1e-10)))
        norm = entropy / np.log2(36)
        return float(1 / (1 + np.exp(-(norm - 0.78) / 0.08)))

    # ── Helpers ──────────────────────────────────────────────────────

    @staticmethod
    def _get_crop(image: np.ndarray, bb: BoundingBox) -> np.ndarray:
        return image[bb.y_min:bb.y_max, bb.x_min:bb.x_max]

    @staticmethod
    def _whole_page(image: np.ndarray) -> List[RegionResult]:
        h, w = image.shape[:2]
        return [RegionResult(
            region_class=RegionClass.PRINTED_TEXT,
            detection_confidence=0.5,
            bbox=BoundingBox(x=0, y=0, w=w, h=h),
            metadata={"detection_method": "whole_page_fallback"},
        )]

    @staticmethod
    def _sort_reading_order(regions: List[RegionResult],
                             band_height: int = 50) -> List[RegionResult]:
        def key(r: RegionResult):
            cy = (r.bbox.y_min + r.bbox.y_max) / 2
            cx = (r.bbox.x_min + r.bbox.x_max) / 2
            return (int(cy / band_height), cx)
        return sorted(regions, key=key)


