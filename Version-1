import re
CHECKBOX_PATTERN = re.compile(r"YES\s*/?\s*NO", re.IGNORECASE)

def route_region(rv: RoutingVector,
                 available_experts: set) -> RoutingDecision:
    """
    Rule-based MoE router implementing the canonical routing table [P26][P27].
    """
    rc = rv.region_class
    qt = rv.quality_tier

    def pick(experts: List[ExpertID], rationale: str) -> RoutingDecision:
        selected = [e for e in experts if e in available_experts]
        if not selected:
            for fb in [ExpertID.B, ExpertID.TESSERACT]:
                if fb in available_experts:
                    selected = [fb]
                    break
            if not selected:
                selected = [ExpertID.TESSERACT]
        return RoutingDecision(expert_ids=selected, rationale=rationale)

    # ── Indian script override ───────────────────────────────────────
    if rv.script_flag:
        return pick([ExpertID.F, ExpertID.E, ExpertID.B],
                     "Indian script detected (>20% non-Latin) [P14]")

    # ── Checkbox YES/NO routing ────────────────────────────────────
    # FIX 6: rv.probe_text was accessed here but the field did not exist on
    # RoutingVector (see FIX 4/5). With the field now declared and populated
    # this branch works correctly.
    if rv.probe_text and CHECKBOX_PATTERN.search(rv.probe_text):
        return pick([ExpertID.D, ExpertID.B],
                     "YES/NO checkbox detected in probe → Expert D (GOT-OCR) [P11]")

    # FIX-9: Remove the > 0 guard so zero-confidence regions also escalate.
    threshold = config.get_escalation_threshold(rc.value)
    if rv.probe_confidence < threshold:
        # FIX-9: Handle zero-confidence case specifically
        if rv.probe_confidence == 0.0:
            _ink = rv.laplacian_variance  # proxy: low lap_var likely blank
            if rc == RegionClass.PRINTED_TEXT and qt == QualityTier.HIGH:
                return pick([ExpertID.D],
                             "Zero-confidence PRINTED+HIGH → Expert D (GOT-OCR) only [FIX-9]")
            elif rc == RegionClass.HANDWRITING:
                return pick([ExpertID.A],
                             "Zero-confidence HANDWRITING → Expert A (TrOCR) only [FIX-9]")
            elif qt == QualityTier.LOW:
                return pick([ExpertID.E],
                             "Zero-confidence LOW quality → Expert E [FIX-9]")
            # ink_density < 0.03 check is done upstream in _process_page blank guard
        return pick([ExpertID.E, ExpertID.D, ExpertID.B],
                     f"Probe confidence {rv.probe_confidence:.2f} < {threshold:.2f} ({rc.value} threshold) — escalate [P12]")

    # ── Main routing table ───────────────────────────────────────────
    if rc == RegionClass.TABLE:
        return pick([ExpertID.D, ExpertID.E, ExpertID.B],
                     "TABLE region → Expert D (GOT-OCR 2.0) [P11]")

    if rc == RegionClass.FORM_FIELD:
        return pick([ExpertID.G, ExpertID.B],
                     "FORM_FIELD → Expert G (Donut) or B [P17]")

    if rc == RegionClass.HANDWRITING:
        if qt == QualityTier.HIGH:
            return pick([ExpertID.A],
                         "HANDWRITTEN + HIGH → Expert A (TrOCR) [P8]")
        elif qt == QualityTier.MEDIUM:
            return pick([ExpertID.A, ExpertID.A_LITE],
                         "HANDWRITTEN + MEDIUM → Expert A or A-Lite [P8][P22]")
        else:
            return pick([ExpertID.E, ExpertID.A, ExpertID.B],
                         "HANDWRITTEN + LOW → Expert E (Qwen2-VL) [P13]")

    if rc == RegionClass.PRINTED_TEXT:
        # FIX-6: Lowered B→C routing thresholds. Expert C only for genuinely
        # low probe confidence, not the 0.70-0.84 range where B is sufficient.
        if qt == QualityTier.HIGH:
            experts = [ExpertID.B]
            if rv.probe_confidence < 0.65:
                experts.append(ExpertID.C)
            return pick(experts,
                         f"PRINTED + HIGH → Expert B (conf={rv.probe_confidence:.2f}) [P9][P10]")
        elif qt == QualityTier.MEDIUM:
            experts = [ExpertID.B]
            if rv.probe_confidence < 0.55:
                experts.append(ExpertID.C)
            return pick(experts,
                         f"PRINTED + MEDIUM → Expert B (conf={rv.probe_confidence:.2f}) [P9][P10]")
        else:
            # FIX-6: LOW quality only — Expert E is allowed here
            return pick([ExpertID.D, ExpertID.E, ExpertID.B],
                         "PRINTED + LOW → Expert D + E [P11][P13]")

    if rv.complexity_score > 0.6:
        return pick([ExpertID.D, ExpertID.E, ExpertID.B],
                     f"MIXED_COMPLEX (complexity={rv.complexity_score:.2f}) → D + E [P11][P13]")

    if rc in (RegionClass.VISUAL_ELEMENT, RegionClass.FIGURE,
              RegionClass.STAMP, RegionClass.SIGNATURE):
        return RoutingDecision(
            expert_ids=[],
            rationale=f"Visual element ({rc.value}) — skip OCR",
        )

    return pick([ExpertID.B, ExpertID.TESSERACT],
                 f"Default route for {rc.value} + {qt.value}")


