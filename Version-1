# ## 9 · Stage 5 — Post-OCR Correction & Provenance Assembly [P23][P24]

# %%

COMMON_DRUG_PREFIXES = {
    "tab", "cap", "inj", "syp", "oint", "susp", "sol", "liq",
    "amp", "vial", "drp", "neb", "inh",
}

COMMON_UNITS = {
    "mg", "ml", "mcg", "iu", "gm", "kg", "cc", "units",
    "od", "bd", "tds", "qid", "hs", "prn", "sos", "stat",
    "ac", "pc", "po", "iv", "im", "sc", "sl",
}


def flag_low_confidence_tokens(word_tokens: List[WordToken],
                                 threshold: float = 0.40) -> List[WordToken]:
    for wt in word_tokens:
        if wt.confidence < threshold:
            wt.error_probability = max(wt.error_probability,
                                        1.0 - wt.confidence)
    return word_tokens


def apply_medical_heuristics(word_tokens: List[WordToken]) -> List[WordToken]:
    for wt in word_tokens:
        lower = wt.word.lower().rstrip(".,;:")
        if lower in COMMON_DRUG_PREFIXES or lower in COMMON_UNITS:
            wt.confidence = min(1.0, wt.confidence + 0.15)
            wt.error_probability = max(0.0, wt.error_probability - 0.15)
        if len(wt.word) <= 2 and wt.confidence < 0.5:
            wt.error_probability = max(wt.error_probability, 0.5)
    return word_tokens


def assemble_provenance(
    region: RegionResult,
    expert_output: ExpertOutput,
    routing_decision: RoutingDecision,
    routing_vector: RoutingVector,
    doc_id: str,
    page_no: int,
) -> RegionResult:
    tokens = flag_low_confidence_tokens(expert_output.word_tokens)
    tokens = apply_medical_heuristics(tokens)

    region.text = expert_output.raw_text
    region.word_tokens = tokens
    region.expert_id = expert_output.expert_id
    region.routing_vector = routing_vector
    region.routing_decision = routing_decision
    region.inference_time_ms = expert_output.inference_time_ms
    region.metadata["doc_id"] = doc_id
    region.metadata["page_no"] = page_no
    region.metadata["char_conf_mean"] = round(expert_output.char_confidence_mean, 3)
    region.metadata["word_conf_mean"] = round(expert_output.word_confidence_mean, 3)

    return region


print("✓ Stage 5 — Post-OCR Correction & Provenance ready")

