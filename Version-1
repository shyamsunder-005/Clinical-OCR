class ExpertG_Donut(OCRExpert):
    expert_id = ExpertID.G

    def __init__(self):
        self._model = None
        self._processor = None

    # FIX-8: Auto-detect task prompt token from tokenizer special tokens.
    def load(self):
        if self._loaded:
            return
        self._task_prompt = None
        try:
            from transformers import DonutProcessor, VisionEncoderDecoderModel
            logger.info("Loading Expert G (Donut): %s → %s",
                         config.DONUT_MODEL, config.DEVICE_LIGHT)
            self._processor = DonutProcessor.from_pretrained(config.DONUT_MODEL)
            self._model = VisionEncoderDecoderModel.from_pretrained(config.DONUT_MODEL)
            self._model.config.tie_word_embeddings = False
            self._model.decoder.config.tie_word_embeddings = False
            self._model.eval().to(config.DEVICE_LIGHT)

            # Auto-detect the correct task token from special tokens
            _special = self._processor.tokenizer.all_special_tokens
            _task_candidates = [t for t in _special
                                if t.startswith("<s_") and t != "<s>"]
            if _task_candidates:
                self._task_prompt = _task_candidates[0]
                logger.info("✓ Expert G: auto-detected task token: %s", self._task_prompt)
            else:
                logger.warning("Expert G: no <s_*> task token found in special tokens %s. "
                               "Expert G marked unavailable.", _special[:10])
                self._model = None

            self._loaded = True
            if self._model is not None:
                logger.info("✓ Expert G loaded on %s", config.DEVICE_LIGHT)
        except Exception as e:
            logger.warning("Donut load failed (%s). Expert G unavailable.", e)
            self._model = None
            self._loaded = True

    def recognize(self, crop: np.ndarray, bbox: BoundingBox) -> ExpertOutput:
        t0 = time.perf_counter()
        self.load()

        if self._model is None or self._task_prompt is None:
            return ExpertOutput(expert_id=self.expert_id,
                                raw_text="[Expert G unavailable]")

        pil = self._to_pil(crop)
        task_prompt = self._task_prompt
        decoder_input_ids = self._processor.tokenizer(
            task_prompt, add_special_tokens=False,
            return_tensors="pt").input_ids.to(config.DEVICE_LIGHT)

        pixel_values = self._processor(pil, return_tensors="pt").pixel_values
        pixel_values = pixel_values.to(config.DEVICE_LIGHT)

        from transformers import GenerationConfig
        _gen_cfg = GenerationConfig(
            max_length=self._model.decoder.config.max_position_embeddings,
            pad_token_id=self._processor.tokenizer.pad_token_id,
            eos_token_id=self._processor.tokenizer.eos_token_id,
            bad_words_ids=[[self._processor.tokenizer.unk_token_id]],
            do_sample=False,
        )
        with torch.no_grad():
            out = self._model.generate(
                pixel_values,
                decoder_input_ids=decoder_input_ids,
                generation_config=_gen_cfg,
                return_dict_in_generate=True,
            )

        text = self._processor.batch_decode(out.sequences)[0]
        # FIX-8: Plain text extraction instead of CORD JSON parsing.
        # Strip task prompt, EOS, and any remaining special tokens.
        import re as _re_g
        text = text.replace(task_prompt, "").replace("</s>", "")
        # Remove any remaining XML-like tags from structured output
        text = _re_g.sub(r'<[^>]+>', ' ', text)
        # Collapse whitespace
        clean_text = _re_g.sub(r'\s+', ' ', text).strip()

        elapsed = (time.perf_counter() - t0) * 1000
        return ExpertOutput(
            raw_text=clean_text,
            word_tokens=self._text_to_word_tokens(clean_text, self.expert_id,
                                                   0.6, bbox),
            char_confidence_mean=0.6,
            word_confidence_mean=0.6,
            expert_id=self.expert_id,
            inference_time_ms=elapsed,
        )

print("✓ Expert G (Donut) defined")

