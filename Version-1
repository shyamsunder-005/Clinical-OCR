class ExpertD_GOT_OCR(OCRExpert):
    expert_id = ExpertID.D

    def __init__(self):
        self._model = None
        self._tokenizer = None

    def is_available(self) -> bool:
        try:
            from transformers import AutoModel, AutoTokenizer  # noqa: F401
            return True
        except ImportError:
            return False

    def load(self):
        if self._loaded:
            return
        try:
            from transformers import AutoModel, AutoTokenizer, PreTrainedTokenizer
            logger.info("Loading Expert D (GOT-OCR 2.0): %s → %s",
                         config.GOT_OCR_MODEL, config.DEVICE_HEAVY)

            _orig_init = PreTrainedTokenizer.__init__
            def _patched_init(self, *args, **kwargs):
                self.mergeable_ranks = {}
                _orig_init(self, *args, **kwargs)
            PreTrainedTokenizer.__init__ = _patched_init

            try:
                self._tokenizer = AutoTokenizer.from_pretrained(
                    config.GOT_OCR_MODEL, trust_remote_code=True)
            finally:
                PreTrainedTokenizer.__init__ = _orig_init

            self._model = AutoModel.from_pretrained(
                config.GOT_OCR_MODEL, trust_remote_code=True,
                low_cpu_mem_usage=True,
                device_map=config.DEVICE_HEAVY,
                torch_dtype=torch.float16,
                use_safetensors=True,
            )
            self._model.eval()
            self._loaded = True
            logger.info("✓ Expert D loaded on %s", config.DEVICE_HEAVY)
        except Exception as e:
            logger.warning("GOT-OCR 2.0 load failed (%s). Expert D unavailable.", e)
            self._loaded = True
            self._model = None

    def unload(self):
        if self._model is not None and not config.CO_RESIDENT:
            self._model.to("cpu")
            torch.cuda.empty_cache()
        self._loaded = False

    def recognize(self, crop: np.ndarray, bbox: BoundingBox) -> ExpertOutput:
        t0 = time.perf_counter()
        self.load()

        if self._model is None:
            return ExpertOutput(expert_id=self.expert_id,
                                raw_text="[Expert D unavailable]")

        # FIX-12: Use /dev/shm (RAM-backed) instead of disk for temp file I/O.
        # Falls back to regular temp if /dev/shm is unavailable.
        import uuid as _uuid
        _shm_dir = "/dev/shm" if os.path.isdir("/dev/shm") else None
        if _shm_dir:
            tmp_path = f"/dev/shm/got_ocr_{_uuid.uuid4().hex[:8]}.png"
        else:
            _tf = tempfile.NamedTemporaryFile(suffix=".png", delete=False)
            tmp_path = _tf.name
            _tf.close()

        pil = self._to_pil(crop)
        pil.save(tmp_path)

        try:
            with torch.no_grad():
                text = self._model.chat(self._tokenizer, tmp_path, ocr_type="ocr")
            text = text.strip() if isinstance(text, str) else str(text).strip()
        except Exception as e:
            logger.warning("GOT-OCR inference failed (%s).", e)
            text = ""
        finally:
            try:
                os.unlink(tmp_path)
            except OSError:
                pass

        # FIX-2: Estimate confidence from output text characteristics instead
        # of hardcoding 0.7. GOT-OCR 2.0 does not return per-token confidence.
        words = text.split()
        n_words = len(words)
        if n_words == 0:
            conf = 0.0
        else:
            # Check for garbage patterns: long runs of special chars, all-caps noise
            import re as _re_d
            _garbage_ratio = sum(1 for w in words if _re_d.fullmatch(r'[^a-zA-Z0-9]{2,}', w)) / n_words
            _short_ratio = sum(1 for w in words if len(w) <= 2) / n_words
            if _garbage_ratio > 0.4:
                conf = 0.2
            elif _short_ratio > 0.6 and n_words > 5:
                conf = 0.3  # mostly 1-2 char tokens = noise
            else:
                conf = min(0.72, 0.80)  # reasonable output, cap at 0.80

        elapsed = (time.perf_counter() - t0) * 1000
        return ExpertOutput(
            raw_text=text,
            word_tokens=self._text_to_word_tokens(text, self.expert_id, conf, bbox),
            char_confidence_mean=conf,
            word_confidence_mean=conf,
            expert_id=self.expert_id,
            inference_time_ms=elapsed,
        )

