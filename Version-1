def segment_lines(binary_image: np.ndarray,
                   min_line_height: int = 8) -> List[np.ndarray]:
    inv = (255 - binary_image) if np.mean(binary_image) > 127 else binary_image.copy()
    proj = np.sum(inv, axis=1).astype(float)
    if proj.max() < 1:
        return [binary_image]

    threshold = proj.max() * 0.05
    is_text = proj > threshold
    diff = np.diff(is_text.astype(np.int8))
    starts = list(np.where(diff == 1)[0] + 1)
    ends   = list(np.where(diff == -1)[0] + 1)

    if is_text[0]:
        starts.insert(0, 0)
    if is_text[-1]:
        ends.append(len(proj))
    if not starts or not ends:
        return [binary_image]

    n = min(len(starts), len(ends))
    starts, ends = starts[:n], ends[:n]

    ms, me = [starts[0]], []
    for i in range(1, n):
        if starts[i] - ends[i-1] < 5:
            continue
        me.append(ends[i-1])
        ms.append(starts[i])
    me.append(ends[-1])

    h = binary_image.shape[0]
    pad = 3
    lines = []
    for s, e in zip(ms, me):
        crop = binary_image[max(0, s-pad):min(h, e+pad), :]
        if crop.shape[0] >= min_line_height:
            lines.append(crop)
    return lines if lines else [binary_image]


class ExpertA_TrOCR(OCRExpert):
    expert_id = ExpertID.A

    def __init__(self):
        self._model = None
        self._processor = None

    def load(self):
        if self._loaded:
            return
        from transformers import TrOCRProcessor, VisionEncoderDecoderModel
        logger.info("Loading Expert A (TrOCR): %s → %s",
                     config.TROCR_MODEL, config.DEVICE_LIGHT)
        self._processor = TrOCRProcessor.from_pretrained(config.TROCR_MODEL)
        self._model = VisionEncoderDecoderModel.from_pretrained(config.TROCR_MODEL)
        self._model.eval().to(config.DEVICE_LIGHT)
        self._loaded = True
        logger.info("✓ Expert A loaded on %s", config.DEVICE_LIGHT)

    def unload(self):
        if self._model is not None:
            self._model.to("cpu")
            torch.cuda.empty_cache()
        self._loaded = False

    def recognize(self, crop: np.ndarray, bbox: BoundingBox) -> ExpertOutput:
        t0 = time.perf_counter()
        self.load()

        gray = cv2.cvtColor(crop, cv2.COLOR_BGR2GRAY) if len(crop.shape) == 3 else crop
        _, binary = cv2.threshold(gray, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)
        line_imgs = segment_lines(binary)
        logger.info("Expert A: %d line(s) segmented", len(line_imgs))

        texts = []
        confidences = []
        for line_img in line_imgs:
            pil = self._to_pil(line_img)
            pixel_values = self._processor(
                images=pil, return_tensors="pt"
            ).pixel_values.to(config.DEVICE_LIGHT)

            with torch.no_grad():
                out = self._model.generate(
                    pixel_values, max_new_tokens=256,
                    output_scores=True, return_dict_in_generate=True,
                )
            text = self._processor.batch_decode(
                out.sequences, skip_special_tokens=True
            )[0].strip()

            if hasattr(out, 'scores') and out.scores:
                probs = [torch.softmax(s, dim=-1).max().item() for s in out.scores]
                conf = float(np.mean(probs)) if probs else 0.5
            else:
                conf = 0.5

            if text:
                texts.append(text)
                confidences.append(conf)

        full_text = "\n".join(texts)
        avg_conf = float(np.mean(confidences)) if confidences else 0.0
        elapsed = (time.perf_counter() - t0) * 1000

        return ExpertOutput(
            raw_text=full_text,
            word_tokens=self._text_to_word_tokens(full_text, self.expert_id,
                                                   avg_conf, bbox),
            char_confidence_mean=avg_conf,
            word_confidence_mean=avg_conf,
            expert_id=self.expert_id,
            inference_time_ms=elapsed,
        )

