# ### Expert Pool Manager & Confidence Fusion

# %%

class ExpertPool:
    def __init__(self):
        self.experts: Dict[ExpertID, OCRExpert] = {}
        self._init_experts()

    def _init_experts(self):
        all_experts = [
            ExpertA_TrOCR(),
            ExpertB_PaddleOCR(),
            ExpertC_DocTR(),
            ExpertD_GOT_OCR(),
            ExpertE_QwenVL(),
            ExpertG_Donut(),
        ]
        for expert in all_experts:
            self.experts[expert.expert_id] = expert
            logger.info("Registered Expert %s (%s)",
                         expert.expert_id.value, expert.__class__.__name__)

    @property
    def available_experts(self) -> set:
        return set(self.experts.keys()) | {ExpertID.TESSERACT}

    def run_expert(self, expert_id: ExpertID,
                    crop: np.ndarray,
                    bbox: BoundingBox) -> ExpertOutput:
        if expert_id == ExpertID.TESSERACT:
            fb = ExpertB_PaddleOCR()
            fb._use_tesseract = True
            fb._loaded = True
            return fb.recognize(crop, bbox)

        expert = self.experts.get(expert_id)
        if expert is None:
            logger.warning("Expert %s not registered. Tesseract fallback.", expert_id)
            return self.run_expert(ExpertID.TESSERACT, crop, bbox)

        try:
            return expert.recognize(crop, bbox)
        except Exception as e:
            logger.error("Expert %s failed (%s). Tesseract fallback.", expert_id, e)
            return self.run_expert(ExpertID.TESSERACT, crop, bbox)

    def run_multi_expert(self, expert_ids: List[ExpertID],
                          crop: np.ndarray,
                          bbox: BoundingBox) -> ExpertOutput:
        if len(expert_ids) == 0:
            return ExpertOutput(raw_text="[VISUAL — no OCR]",
                                expert_id=ExpertID.TESSERACT)

        if len(expert_ids) == 1:
            return self.run_expert(expert_ids[0], crop, bbox)

        outputs = []
        for eid in expert_ids:
            out = self.run_expert(eid, crop, bbox)
            if out.raw_text.strip() and not out.raw_text.startswith("[Expert"):
                outputs.append(out)

        if not outputs:
            return ExpertOutput(expert_id=expert_ids[0])
        if len(outputs) == 1:
            return outputs[0]

        # FIX-7: Real word-level fusion using zip_longest across expert outputs.
        # Pick the highest-confidence token at each position instead of just
        # picking the single best expert overall.
        from itertools import zip_longest

        # Tokenize each expert's output into word tokens
        expert_word_lists = []
        for out in outputs:
            if out.word_tokens:
                expert_word_lists.append((out.expert_id, out.word_tokens))
            else:
                # Build word tokens from raw_text if missing
                words = out.raw_text.split()
                tokens = [WordToken(word=w, confidence=out.word_confidence_mean,
                                    expert_id=out.expert_id) for w in words if w.strip()]
                expert_word_lists.append((out.expert_id, tokens))

        if not expert_word_lists:
            best = max(outputs, key=lambda o: o.word_confidence_mean)
            total_time = sum(o.inference_time_ms for o in outputs)
            best.inference_time_ms = total_time
            return best

        # Zip word tokens across experts, pick best at each position
        all_token_seqs = [tokens for _, tokens in expert_word_lists]
        fused_tokens: List[WordToken] = []
        expert_contribution: Dict[ExpertID, int] = {}

        for position_tokens in zip_longest(*all_token_seqs, fillvalue=None):
            candidates = [t for t in position_tokens if t is not None]
            if not candidates:
                continue

            # Pick token with highest confidence at this position
            best_token = max(candidates, key=lambda t: t.confidence)
            fused_token = WordToken(
                word=best_token.word,
                bbox=best_token.bbox,
                confidence=best_token.confidence,
                expert_id=best_token.expert_id,
                error_probability=best_token.error_probability,
            )

            # FIX-7: Flag positions where no expert exceeds 0.75 confidence
            if all(t.confidence < 0.75 for t in candidates):
                fused_token.error_probability = max(fused_token.error_probability, 0.5)

            # Flag disagreements between experts
            unique_words = set(t.word.lower() for t in candidates)
            if len(unique_words) > 1 and best_token.confidence < 0.75:
                fused_token.error_probability = max(fused_token.error_probability, 0.4)

            fused_tokens.append(fused_token)
            expert_contribution[best_token.expert_id] = \
                expert_contribution.get(best_token.expert_id, 0) + 1

        # Determine majority contributor
        majority_expert = max(expert_contribution, key=expert_contribution.get) \
            if expert_contribution else outputs[0].expert_id

        fused_text = " ".join(t.word for t in fused_tokens)
        avg_conf = float(np.mean([t.confidence for t in fused_tokens])) \
            if fused_tokens else 0.0

        total_time = sum(o.inference_time_ms for o in outputs)
        return ExpertOutput(
            raw_text=fused_text,
            word_tokens=fused_tokens,
            char_confidence_mean=avg_conf,
            word_confidence_mean=avg_conf,
            expert_id=majority_expert,
            inference_time_ms=total_time,
        )

    def run_probe(self, crop: np.ndarray,
                   bbox: BoundingBox) -> ExpertOutput:
        return self.run_expert(ExpertID.B, crop, bbox)

    def preload_all(self):
        if not config.CO_RESIDENT:
            logger.info("Not co-resident mode — experts load on demand.")
            return
        logger.info("Pre-loading all experts (co-resident dual T4) …")
        for eid, expert in self.experts.items():
            try:
                expert.load()
            except Exception as e:
                logger.warning("Failed to pre-load Expert %s: %s", eid, e)
        logger.info("✓ Expert pre-loading complete")


expert_pool = ExpertPool()
print(f"✓ Expert Pool ready ({len(expert_pool.experts)} experts registered)")

