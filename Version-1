            logger.info("✓ Expert C loaded (DocTR on CPU)")
        except Exception as e:
            logger.warning("DocTR load failed (%s). Expert C unavailable.", e)
            self._model = None
        self._loaded = True

    def recognize(self, crop: np.ndarray, bbox: BoundingBox) -> ExpertOutput:
        t0 = time.perf_counter()
        self.load()

        if self._model is None:
            # FIX 8: The original code created ExpertB_PaddleOCR(), then set
            # _use_tesseract=True and _loaded=True without calling load().
            # With the FIX 7 above (_paddle_v3 now defaults to False in
            # __init__), this is safe, but we also guard _loaded properly so
            # the Tesseract path is taken immediately without trying PaddleOCR.
            expert_b = ExpertB_PaddleOCR()
            expert_b._use_tesseract = True
            expert_b._loaded = True
            return expert_b.recognize(crop, bbox)

        try:
            rgb = cv2.cvtColor(crop, cv2.COLOR_BGR2RGB) if len(crop.shape) == 3 else \
                  cv2.cvtColor(crop, cv2.COLOR_GRAY2RGB)
            result = self._model([rgb])
        except Exception as e:
            logger.warning("DocTR inference failed (%s).", e)
            return ExpertOutput(expert_id=self.expert_id)

        texts = []
        word_tokens = []
        confidences = []
        h_crop, w_crop = crop.shape[:2]

        for page in result.pages:
            for block in page.blocks:
                for line in block.lines:
                    for word in line.words:
                        texts.append(word.value)
                        confidences.append(word.confidence)
                        (x1r, y1r), (x2r, y2r) = word.geometry
                        word_tokens.append(WordToken(
                            word=word.value,
                            bbox=BoundingBox(
                                x=bbox.x + int(x1r * w_crop),
                                y=bbox.y + int(y1r * h_crop),
                                w=int((x2r - x1r) * w_crop),
                                h=int((y2r - y1r) * h_crop),
                            ),
                            confidence=word.confidence,
                            expert_id=self.expert_id,
                        ))

        full_text = " ".join(texts)
        avg_conf = float(np.mean(confidences)) if confidences else 0.0
        elapsed = (time.perf_counter() - t0) * 1000

        return ExpertOutput(
            raw_text=full_text, word_tokens=word_tokens,
            char_confidence_mean=avg_conf, word_confidence_mean=avg_conf,
            expert_id=self.expert_id, inference_time_ms=elapsed,
        )

