class MoEOCRPipeline:
    """Full 6-stage MoE OCR Pipeline for clinical documents."""

    def __init__(self, layout: LayoutDetector, pool: ExpertPool):
        self.layout = layout
        self.pool = pool

    def process_document(self, file_path: str,
                          force_expert: Optional[ExpertID] = None,
                          preload: bool = True) -> DocumentExtractionResult:
        start = time.perf_counter()
        doc_id = uuid.uuid4().hex[:12]
        filename = Path(file_path).name
        logger.info("═" * 60)
        logger.info("  Processing: %s (doc_id=%s)", filename, doc_id)
        logger.info("═" * 60)

        if preload and config.CO_RESIDENT:
            self.pool.preload_all()

        images = ingest_document(file_path)
        logger.info("Ingested %d page(s)", len(images))

        pages = []
        for page_idx, page_image in enumerate(images, start=1):
            page_result = self._process_page(page_image, page_idx, doc_id, force_expert)
            pages.append(page_result)

        elapsed = time.perf_counter() - start
        result = DocumentExtractionResult(
            document_id=doc_id,
            source_doc_id=doc_id,
            filename=filename,
            total_pages=len(pages),
            pages=pages,
            processing_time_seconds=round(elapsed, 3),
        )
        logger.info("═" * 60)
        logger.info("  DONE: %s — %.2fs (%d pages)", filename, elapsed, len(pages))
        logger.info("═" * 60)
        return result

    def _process_page(self, page_image: np.ndarray, page_no: int,
                       doc_id: str,
                       force_expert: Optional[ExpertID]) -> PageExtractionResult:
        h, w = page_image.shape[:2]
        logger.info("─── Page %d (%d×%d) ───", page_no, w, h)

        # Stage 0
        preprocessed, page_quality_var, page_quality_tier = preprocess_page(page_image)

        # Stage 1
        regions = self.layout.detect(page_image, preprocessed)
        class_counts: Dict[str, int] = {}
        for r in regions:
            class_counts[r.region_class.value] = class_counts.get(r.region_class.value, 0) + 1
        logger.info("Stage 1: %d regions — %s", len(regions), class_counts)

        all_classes = [r.region_class for r in regions]

        routing_log: List[RoutingLogEntry] = []
        all_word_tokens: List[WordToken] = []

        page_h, page_w = page_image.shape[:2]
        page_area = page_h * page_w

        for seq_id, region in enumerate(regions):
            crop = page_image[region.bbox.y_min:region.bbox.y_max,
                              region.bbox.x_min:region.bbox.x_max]
            if crop.size == 0:
                continue

            # Blank Region Guard
            gray_crop = cv2.cvtColor(crop, cv2.COLOR_BGR2GRAY) if len(crop.shape) == 3 else crop
            ink_density = float(np.sum(gray_crop < 200)) / max(gray_crop.size, 1)
            if ink_density < 0.01:
                logger.info("  Region %d: blank region (ink=%.1f%%) — skipping",
                             seq_id, 100 * ink_density)
                continue

            # FIX-5: Only call detect_and_correct_rotation() when criteria are met:
            # - Non-standard aspect ratio (h > 1.5*w OR w > 3*h for text regions)
            # - OR probe confidence extremely low (<0.20) AND ink > 5%
            # - OR handwriting with HW score > 0.80
            crop_h, crop_w = crop.shape[:2]
            _hw_score = region.metadata.get("handwriting_score", 0.0)
            _needs_rotation_check = (
                (crop_h > 1.5 * crop_w) or (crop_w > 3 * crop_h) or
                (_hw_score > 0.80)
                # probe_confidence check deferred since probe hasn't run yet
            )
            if _needs_rotation_check and ink_density > 0.05:
                crop, angle = detect_and_correct_rotation(crop)
                if angle:
                    region.metadata["rotation_corrected"] = angle
            else:
                angle = 0

            # FIX-3: Full-page region guard — replace hardcoded Expert E with
            # grid_aware_split() and normal routing flow.
            region_area = (region.bbox.x_max - region.bbox.x_min) * \
                          (region.bbox.y_max - region.bbox.y_min)
            if region_area > 0.60 * page_area:
                gray_crop = (cv2.cvtColor(crop, cv2.COLOR_BGR2GRAY)
                             if len(crop.shape) == 3 else crop)
                ink_density = float(np.sum(gray_crop < 200)) / gray_crop.size
                if ink_density < 0.02:
                    logger.info(
                        "  Region %d: full-page region appears BLANK "
                        "(ink=%.1f%%) — skipping OCR",
                        seq_id, 100 * ink_density)
                    _rv_blank = compute_routing_vector(
                        region_crop=crop, region=region,
                        page_quality_tier=page_quality_tier,
                        page_region_classes=all_classes,
                        probe_text="", probe_confidence=0.0,
                    )
                    _dec_blank = RoutingDecision(expert_ids=[], rationale="Blank page — no OCR")
                    _out_blank = ExpertOutput(
                        raw_text="", expert_id=ExpertID.B,
                        char_confidence_mean=0.0, word_confidence_mean=0.0)
                    region = assemble_provenance(
                        region, _out_blank, _dec_blank, _rv_blank, doc_id, page_no)
                    routing_log.append(RoutingLogEntry(
                        region_id=region.region_id,
                        routing_vector=_rv_blank,
                        experts_invoked=[],
                        fusion_method="none",
                        total_time_ms=0.0,
                    ))
                    continue

                # FIX-3: Always try grid_aware_split() on full-page regions
                # with ink_density > 0.02 — but skip if already split by detect()
                _already_split = region.metadata.get("detection_method") == "grid_aware_split"
                if not _already_split and ink_density > 0.02:
                    sub_regions = grid_aware_split(page_image, region)

                    # FIX-10: Minimum sub-region count check for multi-section docs.
                    # Only apply forced-thirds split for HANDWRITING or mixed (HW > 0.4).
                    _is_hw_or_mixed = (
                        region.region_class == RegionClass.HANDWRITING or
                        region.metadata.get("handwriting_score", 0.0) > 0.4
                    )
                    if len(sub_regions) < 3 and _is_hw_or_mixed:
                        # Check if page has > 5 horizontal lines
                        _gray_page = cv2.cvtColor(page_image, cv2.COLOR_BGR2GRAY) \
                            if len(page_image.shape) == 3 else page_image
                        _edges = cv2.Canny(_gray_page, 50, 150, apertureSize=3)
                        _lines = cv2.HoughLinesP(_edges, 1, np.pi / 180,
                                                  threshold=100,
                                                  minLineLength=page_w // 6,
                                                  maxLineGap=20)
                        _h_count = 0
                        if _lines is not None:
                            _h_count = sum(1 for l in _lines
                                           for x1, y1, x2, y2 in [l[0]]
                                           if abs(y1 - y2) < 5)
                        if _h_count > 5:
                            logger.info("    ↳ FIX-10: Forcing 3 row-based splits "
                                        "(%d h-lines, %d sub-regions, HW/mixed)",
                                        _h_count, len(sub_regions))
                            _ph, _pw = page_image.shape[:2]
                            _third = _ph // 3
                            sub_regions = []
                            for _i in range(3):
                                _y1 = _i * _third
                                _y2 = (_i + 1) * _third if _i < 2 else _ph
                                sub_regions.append(RegionResult(
                                    region_class=region.region_class,
                                    detection_confidence=region.detection_confidence * 0.85,
                                    bbox=BoundingBox(x=0, y=_y1, w=_pw, h=_y2 - _y1),
                                    metadata={"detection_method": "forced_thirds_split"},
                                ))

                    if len(sub_regions) > 1:
                        logger.info("    ↳ FIX-3: Full-page split into %d sub-regions → "
                                    "routing each through Stage 2→3",
                                    len(sub_regions))
                        # Process each sub-region through normal routing
                        for sub_seq, sub_region in enumerate(sub_regions):
                            sub_crop = page_image[
                                sub_region.bbox.y_min:sub_region.bbox.y_max,
                                sub_region.bbox.x_min:sub_region.bbox.x_max]
                            if sub_crop.size == 0:
                                continue
                            _sub_gray = cv2.cvtColor(sub_crop, cv2.COLOR_BGR2GRAY) \
                                if len(sub_crop.shape) == 3 else sub_crop
                            _sub_ink = float(np.sum(_sub_gray < 200)) / max(_sub_gray.size, 1)
                            if _sub_ink < 0.01:
                                continue

                            sub_probe = self.pool.run_probe(sub_crop, sub_region.bbox)
                            sub_rv = compute_routing_vector(
                                region_crop=sub_crop, region=sub_region,
                                page_quality_tier=page_quality_tier,
                                page_region_classes=all_classes,
                                probe_text=sub_probe.raw_text,
                                probe_confidence=sub_probe.word_confidence_mean,
                            )
                            if force_expert is not None:
                                sub_dec = RoutingDecision(
                                    expert_ids=[force_expert],
                                    rationale=f"Forced: {force_expert.value}")
                            else:
                                sub_dec = route_region(sub_rv, self.pool.available_experts)

                            logger.info("    Sub-region %d.%d [%s %s]: → %s",
                                         seq_id, sub_seq,
                                         sub_region.region_class.value,
                                         sub_rv.quality_tier.value,
                                         [e.value for e in sub_dec.expert_ids])

                            if not sub_dec.expert_ids:
                                sub_out = ExpertOutput(raw_text="[VISUAL ELEMENT]",
                                                       expert_id=ExpertID.TESSERACT)
                            elif (len(sub_dec.expert_ids) == 1
                                  and sub_dec.expert_ids[0] == ExpertID.B
                                  and sub_probe.raw_text.strip()):
                                sub_out = sub_probe
                                # FIX-11: Override expert_id when reusing probe
                                sub_out.expert_id = ExpertID.B
                            else:
                                sub_out = self.pool.run_multi_expert(
                                    sub_dec.expert_ids, sub_crop, sub_region.bbox)

                            sub_region = assemble_provenance(
                                sub_region, sub_out, sub_dec, sub_rv, doc_id, page_no)
                            all_word_tokens.extend(sub_region.word_tokens)
                            routing_log.append(RoutingLogEntry(
                                region_id=sub_region.region_id,
                                routing_vector=sub_rv,
                                experts_invoked=sub_dec.expert_ids,
                                fusion_method="single" if len(sub_dec.expert_ids) <= 1
                                    else "word_level_fusion",
                                total_time_ms=sub_out.inference_time_ms,
                            ))
                        continue  # skip normal processing for this region

                # FIX-3: Single-region fallback — split failed or already split
                # HANDWRITING → Expert A + D (not E). PRINTED_TEXT → Expert B + D (not E).
                if region.region_class == RegionClass.HANDWRITING:
                    _fp_experts = [ExpertID.A, ExpertID.D]
                    _fp_rationale = "Full-page HANDWRITING → Expert A + D [FIX-3]"
                else:
                    _fp_experts = [ExpertID.B, ExpertID.D]
                    _fp_rationale = "Full-page PRINTED_TEXT → Expert B + D [FIX-3]"

                logger.info("  Region %d: full-page %s (%.0f%% of page) → %s",
                             seq_id, region.region_class.value,
                             100 * region_area / page_area,
                             [e.value for e in _fp_experts])
                expert_output = self.pool.run_multi_expert(
                    _fp_experts, crop, region.bbox)
                routing_vector = compute_routing_vector(
                    region_crop=crop, region=region,
                    page_quality_tier=page_quality_tier,
                    page_region_classes=all_classes,
                    probe_text=expert_output.raw_text,
                    probe_confidence=expert_output.word_confidence_mean,
                )
                decision = RoutingDecision(
                    expert_ids=_fp_experts, rationale=_fp_rationale)
                region = assemble_provenance(
                    region, expert_output, decision, routing_vector, doc_id, page_no)
                all_word_tokens.extend(region.word_tokens)
                routing_log.append(RoutingLogEntry(
                    region_id=region.region_id,
                    routing_vector=routing_vector,
                    experts_invoked=decision.expert_ids,
                    fusion_method="word_level_fusion",
                    total_time_ms=expert_output.inference_time_ms,
                ))
                continue

            # Stage 2
            probe = self.pool.run_probe(crop, region.bbox)
            probe_conf = probe.word_confidence_mean
            probe_text = probe.raw_text

            # FIX-5: Deferred rotation check — if probe confidence is extremely
            # low and we didn't already check rotation, try now.
            if not _needs_rotation_check and probe_conf < 0.20 and ink_density > 0.05:
                crop, angle = detect_and_correct_rotation(crop)
                if angle:
                    region.metadata["rotation_corrected"] = angle
                    # Re-run probe after rotation correction
                    probe = self.pool.run_probe(crop, region.bbox)
                    probe_conf = probe.word_confidence_mean
                    probe_text = probe.raw_text

            routing_vector = compute_routing_vector(
                region_crop=crop,
                region=region,
                page_quality_tier=page_quality_tier,
                page_region_classes=all_classes,
                probe_text=probe_text,
                probe_confidence=probe_conf,
            )

            # Stage 3
            if force_expert is not None:
                decision = RoutingDecision(
                    expert_ids=[force_expert],
                    rationale=f"Forced expert override: {force_expert.value}",
                )
            else:
                decision = route_region(routing_vector, self.pool.available_experts)

            logger.info("  Region %d [%s %s]: → %s (%s)",
                         seq_id, region.region_class.value,
                         routing_vector.quality_tier.value,
                         [e.value for e in decision.expert_ids],
                         decision.rationale[:60])

            # Stage 4
            if not decision.expert_ids:
                expert_output = ExpertOutput(
                    raw_text="[VISUAL ELEMENT]",
                    expert_id=ExpertID.TESSERACT,
                )
            elif (len(decision.expert_ids) == 1
                  and decision.expert_ids[0] == ExpertID.B):
                if probe.raw_text.strip():
                    expert_output = probe
                    # FIX-11: Override expert_id to B when reusing probe,
                    # preserving transparency via metadata flags.
                    expert_output.expert_id = ExpertID.B
                    region.metadata["probe_reused"] = True
                    region.metadata["actual_engine"] = (
                        "tesseract_fallback" if getattr(
                            self.pool.experts.get(ExpertID.B), '_use_tesseract', False)
                        else "paddleocr")
                    logger.info("    ↳ Reusing Expert B probe (%.0fms)",
                                 probe.inference_time_ms)
                else:
                    logger.info("    ↳ Expert B probe empty — escalating to Expert C")
                    expert_output = self.pool.run_multi_expert(
                        [ExpertID.C], crop, region.bbox)
            else:
                expert_output = self.pool.run_multi_expert(
                    decision.expert_ids, crop, region.bbox)

            # Stage 5
            region = assemble_provenance(
                region, expert_output, decision, routing_vector, doc_id, page_no)
            all_word_tokens.extend(region.word_tokens)

            routing_log.append(RoutingLogEntry(
                region_id=region.region_id,
                routing_vector=routing_vector,
                experts_invoked=decision.expert_ids,
                fusion_method="single" if len(decision.expert_ids) <= 1 else "word_level_fusion",
                total_time_ms=expert_output.inference_time_ms,
            ))

        # Quality Report
        n_hw    = sum(1 for r in regions if r.region_class == RegionClass.HANDWRITING)
        n_pr    = sum(1 for r in regions if r.region_class == RegionClass.PRINTED_TEXT)
        n_total = max(len(regions), 1)
        n_low_conf = sum(1 for wt in all_word_tokens if wt.confidence < 0.5)

        quality_report = QualityReport(
            page_quality_tier=page_quality_tier,
            page_laplacian_variance=page_quality_var,
            pct_handwritten=round(n_hw / n_total, 2),
            pct_printed=round(n_pr / n_total, 2),
            pct_low_confidence=round(n_low_conf / max(len(all_word_tokens), 1), 2),
            total_regions=n_total,
        )

        page_text = "\n".join(r.text for r in regions
                               if r.text.strip() and not r.text.startswith("[VISUAL"))

        return PageExtractionResult(
            page_number=page_no, width=w, height=h,
            page_text=page_text,
            word_tokens=all_word_tokens,
            region_map=regions,
            routing_log=routing_log,
            quality_report=quality_report,
        )


pipeline = MoEOCRPipeline(layout=layout_detector, pool=expert_pool)
