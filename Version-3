    @staticmethod
    def _to_pil(image: np.ndarray) -> Image.Image:
        if len(image.shape) == 2:
            return Image.fromarray(cv2.cvtColor(image, cv2.COLOR_GRAY2RGB))
        return Image.fromarray(cv2.cvtColor(image, cv2.COLOR_BGR2RGB))

    @staticmethod
    def _text_to_word_tokens(text: str, expert_id: ExpertID,
                              confidence: float = 0.0,
                              base_bbox: Optional[BoundingBox] = None) -> List[WordToken]:
        words = text.split()
        return [WordToken(word=w, confidence=confidence,
                          expert_id=expert_id, bbox=base_bbox)
                for w in words if w.strip()]


