class MedGemmaValidator:
    def __init__(self):
        self._model = None
        self._tokenizer = None
        self._loaded = False

    def is_available(self) -> bool:
        try:
            import transformers
            return True
        except ImportError:
            return False

    def load(self):
        if self._loaded:
            return
        try:
            from transformers import AutoTokenizer, AutoModelForCausalLM
            import torch
            logger.info("Loading MedGemma (google/medgemma-4b-it) on %s …", config.MEDGEMMA_DEVICE)
            self._tokenizer = AutoTokenizer.from_pretrained(config.MEDGEMMA_MODEL)
            self._model = AutoModelForCausalLM.from_pretrained(
                config.MEDGEMMA_MODEL,
                device_map=config.MEDGEMMA_DEVICE,
                torch_dtype=torch.bfloat16 if config.MEDGEMMA_DEVICE != "cpu" else torch.float32,
            )
            self._model.eval()
            self._loaded = True
            logger.info("✓ MedGemma loaded")
        except Exception as e:
            logger.warning("MedGemma load failed (%s). Validation unavailable.", e)
            self._model = None
            self._loaded = True

    def validate_region(self, text: str) -> MedGemmaResult:
        if not text.strip() or self._model is None:
            return MedGemmaResult(validated_text=text, corrections=[], flags=[], 
                                  medical_confidence=0.0, ambiguities_resolved=[], hallucination_detected=False)

        import torch
        prompt = f"Analyze this OCR text from a medical document. Correct obvious misspellings of drug names and medical terms. Do NOT change the meaning or structure. Return only the corrected text.\n\nText: {text}"
        inputs = self._tokenizer(prompt, return_tensors="pt").to(self._model.device)
        with torch.no_grad():
            outputs = self._model.generate(**inputs, max_new_tokens=512, temperature=0.1, do_sample=False)
        res_text = self._tokenizer.decode(outputs[0][inputs.input_ids.shape[1]:], skip_special_tokens=True).strip()
        
        return MedGemmaResult(
            validated_text=res_text,
            corrections=[], 
            flags=[],
            medical_confidence=0.8,
            ambiguities_resolved=[],
            hallucination_detected=False
        )

def validate_and_package(doc_id: str, filename: str, pages: List[PageExtractionResult], 
                         medgemma: MedGemmaValidator, elapsed: float, metrics: PipelineMetrics) -> OCRResult:
    seen_ids = set()
    all_regions = []
    import numpy as np
    for p in pages:
        for r in p.region_map:
            if r.region_id not in seen_ids and len(r.text.strip()) >= 2:
                mg_res = medgemma.validate_region(r.text)
                r.text = mg_res.validated_text
                r.metadata["medical_confidence"] = mg_res.medical_confidence
                seen_ids.add(r.region_id)
                all_regions.append(r)
    
    doc_text = "\n\n".join(r.text for r in all_regions)
    
    # Calculate means
    conf_vals = [r.metadata.get("calibrated_confidence", 0.0) for r in all_regions]
    med_vals = [r.metadata.get("medical_confidence", 0.0) for r in all_regions]
    
    return OCRResult(
        document_id=doc_id,
        filename=filename,
        total_pages=len(pages),
        pages=pages,
        document_text=doc_text,
        validated_text=doc_text,
        regions=all_regions,
        provenance=[{"pipeline_version": "3.0"}],
        ocr_confidence_mean=float(np.mean(conf_vals)) if conf_vals else 0.0,
        medical_confidence_mean=float(np.mean(med_vals)) if med_vals else 0.0,
        correction_history=[],
        flags=[],
        processing_time_seconds=elapsed,
        metadata={"metrics": metrics.model_dump()}
    )

class MoEOCRPipeline:
    """Full 8-stage MoE OCR Pipeline for clinical documents."""

    def __init__(self, layout: LayoutDetector, pool: ExpertPool, vlm_router: VisionLanguageRouter):
        self.layout = layout
        self.pool = pool
        self.vlm_router = vlm_router
        self.medgemma = MedGemmaValidator()

    def process_document(self, file_path: str,
                          force_expert: Optional[ExpertID] = None,
                          preload: bool = True) -> OCRResult:
        start = time.perf_counter()
        doc_id = uuid.uuid4().hex[:12]
        filename = Path(file_path).name
        logger.info("═" * 60)
        logger.info("  Processing: %s (doc_id=%s)", filename, doc_id)
        logger.info("═" * 60)

        if preload and config.CO_RESIDENT:
            self.pool.preload_all()
            self.vlm_router.load()

        images = ingest_document(file_path)
        logger.info("Ingested %d page(s)", len(images))

        # We'll use a dummy metrics object for now since we don't have all logging fully wired in _process_page
        metrics = PipelineMetrics(gpu_utilization={}, vram_used_gb={}, ocr_latency_ms={}, 
                                  router_latency_ms=0.0, failure_count=0, fallback_count=0, cache_hit_count=0, 
                                  expert_usage={}, router_type_usage={})

        pages = []
        for page_idx, page_image in enumerate(images, start=1):
            page_result = self._process_page(page_image, page_idx, doc_id, force_expert)
            pages.append(page_result)

        elapsed = time.perf_counter() - start
        
        # Stage 6 & 7: MedGemma validation and packaging
        result = validate_and_package(doc_id, filename, pages, self.medgemma, round(elapsed, 3), metrics)
        
        logger.info("═" * 60)
        logger.info("  DONE: %s — %.2fs (%d pages)", filename, elapsed, len(pages))
        logger.info("═" * 60)
        return result

    # FIX-BUGFIX-5: Shared helper to build and append RoutingLogEntry
    @staticmethod
    def _record_routing(routing_log: list, region: RegionResult,
                        rv: RoutingVector, decision: RoutingDecision,
                        output: ExpertOutput, router_type: str) -> None:
        """Build and append a RoutingLogEntry — single code path."""
        routing_log.append(RoutingLogEntry(
            region_id=region.region_id,
            routing_vector=rv,
            experts_invoked=decision.expert_ids,
            fusion_method="single" if len(decision.expert_ids) <= 1 else "priority_tier",
            total_time_ms=output.inference_time_ms,
            router_type=router_type,  # FIX-BUGFIX-4
            crop_area_px=rv.crop_area_px,
        ))

    def _process_page(self, page_image: np.ndarray, page_no: int,
                       doc_id: str,
                       force_expert: Optional[ExpertID]) -> PageExtractionResult:
        h, w = page_image.shape[:2]
        logger.info("─── Page %d (%d×%d) ───", page_no, w, h)

        # Stage 0
        preprocessed, page_quality_var, page_quality_tier = preprocess_page(page_image)

        # Stage 1
        regions = self.layout.detect(page_image, preprocessed)
        class_counts: Dict[str, int] = {}
        for r in regions:
            class_counts[r.region_class.value] = class_counts.get(r.region_class.value, 0) + 1
        logger.info("Stage 1: %d regions — %s", len(regions), class_counts)

        all_classes = [r.region_class for r in regions]

        routing_log: List[RoutingLogEntry] = []
        all_word_tokens: List[WordToken] = []
        processed_regions: List[RegionResult] = [] 

        page_h, page_w = page_image.shape[:2]
        page_area = page_h * page_w

        _stage1_consumed = 0  # FIX-BUGFIX-8: track how many Stage-1 regions were accounted for

        for seq_id, region in enumerate(regions):
            crop = page_image[region.bbox.y_min:region.bbox.y_max,
                              region.bbox.x_min:region.bbox.x_max]
            if crop.size == 0:
                # FIX-BUGFIX-8: log every silent skip with region id and bbox
                logger.info("  Region %d: empty crop (bbox %s out of bounds) — skipping",
                             seq_id, region.bbox)
                _stage1_consumed += 1  # FIX-BUGFIX-8
                continue

            gray_crop = cv2.cvtColor(crop, cv2.COLOR_BGR2GRAY) if len(crop.shape) == 3 else crop
            ink_density = float(np.sum(gray_crop < 200)) / max(gray_crop.size, 1)
            if ink_density < 0.01:
                logger.info("  Region %d: blank region (ink=%.1f%%) — skipping",
                             seq_id, 100 * ink_density)
                _stage1_consumed += 1  # FIX-BUGFIX-8
                continue

            crop_h, crop_w = crop.shape[:2]
            _hw_score = region.metadata.get("handwriting_score", 0.0)
            _needs_rotation_check = (
                (crop_h > 1.5 * crop_w) or (crop_w > 3 * crop_h) or
                (_hw_score > 0.80)
            )
            if _needs_rotation_check and ink_density > 0.05:
                crop, angle = detect_and_correct_rotation(crop)
                if angle:
                    region.metadata["rotation_corrected"] = angle
            else:
                angle = 0

            probe = self.pool.run_probe(crop, region.bbox)
            probe_conf = probe.word_confidence_mean
            probe_text = probe.raw_text

            if not _needs_rotation_check and probe_conf < 0.20 and ink_density > 0.05:
                crop, angle = detect_and_correct_rotation(crop)
                if angle:
                    region.metadata["rotation_corrected"] = angle
                    probe = self.pool.run_probe(crop, region.bbox)
                    probe_conf = probe.word_confidence_mean
                    probe_text = probe.raw_text

            routing_vector = compute_routing_vector(
                region_crop=crop, region=region,
                page_quality_tier=page_quality_tier,
                page_region_classes=all_classes,
                probe_text=probe_text,
                probe_confidence=probe_conf,
            )

            region_area = (region.bbox.x_max - region.bbox.x_min) * (region.bbox.y_max - region.bbox.y_min)
            if region_area > 0.60 * page_area:
                gray_crop = (cv2.cvtColor(crop, cv2.COLOR_BGR2GRAY)
                             if len(crop.shape) == 3 else crop)
                ink_density = float(np.sum(gray_crop < 200)) / gray_crop.size
                if ink_density < 0.02:
                    logger.info("  Region %d: full-page region appears BLANK", seq_id)
                    _dec_blank = RoutingDecision(expert_ids=[], rationale="Blank page — no OCR")
                    _out_blank = ExpertOutput(raw_text="", expert_id=ExpertID.B, char_confidence_mean=0.0, word_confidence_mean=0.0)
                    region = assemble_provenance(region, _out_blank, _dec_blank, routing_vector, doc_id, page_no)
                    processed_regions.append(region)
                    continue

                _already_split = region.metadata.get("detection_method") == "grid_aware_split"
                if not _already_split and ink_density > 0.02:
                    _region_w_frac = (region.bbox.x_max - region.bbox.x_min) / page_w
                    _region_h_frac = (region.bbox.y_max - region.bbox.y_min) / page_h
                    sub_regions = None
                    if _region_w_frac > 0.50 and _region_h_frac > 0.40:
                        two_col = split_two_column_form(page_image, region)
                        if len(two_col) == 2:
                            sub_regions = two_col

                    if sub_regions is None:
                        sub_regions = grid_aware_split(page_image, region)

                    _is_hw_or_mixed = (region.region_class == RegionClass.HANDWRITING or region.metadata.get("handwriting_score", 0.0) > 0.4)
                    if len(sub_regions) < 3 and _is_hw_or_mixed:
                        _gray_page = cv2.cvtColor(page_image, cv2.COLOR_BGR2GRAY) if len(page_image.shape) == 3 else page_image
                        _edges = cv2.Canny(_gray_page, 50, 150, apertureSize=3)
                        _lines = cv2.HoughLinesP(_edges, 1, np.pi / 180, threshold=100, minLineLength=page_w // 6, maxLineGap=20)
                        _h_count = 0
                        if _lines is not None:
                            _h_count = sum(1 for l in _lines for x1, y1, x2, y2 in [l[0]] if abs(y1 - y2) < 5)
                        if _h_count > 5:
                            _ph, _pw = page_image.shape[:2]
                            _third = _ph // 3
                            sub_regions = []
                            for _i in range(3):
                                _y1 = _i * _third
                                _y2 = (_i + 1) * _third if _i < 2 else _ph
                                sub_regions.append(RegionResult(
                                    region_class=region.region_class,
                                    detection_confidence=region.detection_confidence * 0.85,
                                    bbox=BoundingBox(x=0, y=_y1, w=_pw, h=_y2 - _y1),
                                    metadata={"detection_method": "forced_thirds_split"},
                                ))

                    if len(sub_regions) > 1:
                        for sub_seq, sub_region in enumerate(sub_regions):
                            sub_crop = page_image[
                                sub_region.bbox.y_min:sub_region.bbox.y_max,
                                sub_region.bbox.x_min:sub_region.bbox.x_max]
                            if sub_crop.size == 0:
                                # FIX-BUGFIX-8: log sub-region empty crop
                                logger.info("    Sub-region %d: empty crop (bbox %s) — skipping",
                                             sub_seq, sub_region.bbox)
                                continue
                            _sub_gray = cv2.cvtColor(sub_crop, cv2.COLOR_BGR2GRAY) if len(sub_crop.shape) == 3 else sub_crop
                            _sub_ink = float(np.sum(_sub_gray < 200)) / max(_sub_gray.size, 1)
                            if _sub_ink < 0.01:
                                # FIX-BUGFIX-8: log sub-region blank
                                logger.info("    Sub-region %d: blank (ink=%.1f%%) — skipping",
                                             sub_seq, 100 * _sub_ink)
                                continue

                            sub_probe = self.pool.run_probe(sub_crop, sub_region.bbox)
                            sub_rv = compute_routing_vector(
                                region_crop=sub_crop, region=sub_region,
                                page_quality_tier=page_quality_tier,
                                page_region_classes=all_classes,
                                probe_text=sub_probe.raw_text,
                                probe_confidence=sub_probe.word_confidence_mean,
                            )
                            if force_expert is not None:
                                sub_dec = RoutingDecision(expert_ids=[force_expert],
                                                          rationale=f"Forced: {force_expert.value}",
                                                          router_type="forced")  # FIX-BUGFIX-4
                            elif _fast_route_is_certain(sub_rv):
                                sub_dec = route_region_fast(sub_rv, self.pool.available_experts)
                            else:
                                sub_dec = self.vlm_router.route(sub_crop, sub_rv, self.pool.available_experts)

                            if not sub_dec.expert_ids:
                                sub_out = ExpertOutput(raw_text="[VISUAL ELEMENT]", expert_id=ExpertID.TESSERACT)
                            elif len(sub_dec.expert_ids) == 1 and sub_dec.expert_ids[0] == ExpertID.B and sub_probe.raw_text.strip():
                                sub_out = sub_probe
                                sub_out.expert_id = ExpertID.B
                            else:
                                sub_out = self.pool.run_multi_expert(sub_dec.expert_ids, sub_crop, sub_region.bbox)

                            sub_region = assemble_provenance(sub_region, sub_out, sub_dec, sub_rv, doc_id, page_no)
                            # FIX-BUGFIX-5: record routing for sub-regions (was missing)
                            self._record_routing(routing_log, sub_region, sub_rv,
                                                  sub_dec, sub_out, sub_dec.router_type)  # FIX-BUGFIX-4
                            processed_regions.append(sub_region)
                            all_word_tokens.extend(sub_region.word_tokens)
                            
                        _stage1_consumed += 1  # FIX-BUGFIX-8: split region is 1 Stage-1 region
                        continue

                # Full page fallback
                if region.region_class == RegionClass.HANDWRITING:
                    _fp_experts = [ExpertID.A, ExpertID.D]
                else:
                    _fp_experts = [ExpertID.B, ExpertID.D]

                expert_output = self.pool.run_multi_expert(_fp_experts, crop, region.bbox)
                decision = RoutingDecision(expert_ids=_fp_experts, rationale="Full-page fallback")
                region = assemble_provenance(region, expert_output, decision, routing_vector, doc_id, page_no)
                processed_regions.append(region)
                all_word_tokens.extend(region.word_tokens)
                _stage1_consumed += 1  # FIX-BUGFIX-8: full-page fallback
                continue

            # Stage 3 — Two-tier routing 
            if force_expert is not None:
                decision = RoutingDecision(expert_ids=[force_expert],
                                           rationale=f"Forced: {force_expert.value}",
                                           router_type="forced")  # FIX-BUGFIX-4
            elif _fast_route_is_certain(routing_vector):
                decision = route_region_fast(routing_vector, self.pool.available_experts)
            else:
                decision = self.vlm_router.route(crop, routing_vector, self.pool.available_experts)
                # FIX-BUGFIX-4: router_type is now on the decision object itself

            # Stage 4
            if not decision.expert_ids:
                expert_output = ExpertOutput(raw_text="[VISUAL ELEMENT]", expert_id=ExpertID.TESSERACT)
            elif len(decision.expert_ids) == 1 and decision.expert_ids[0] == ExpertID.B:
                if probe.raw_text.strip():
                    expert_output = probe
                    expert_output.expert_id = ExpertID.B
                    region.metadata["probe_reused"] = True
                    region.metadata["actual_engine"] = "tesseract_fallback" if getattr(self.pool.registry.get(ExpertID.B), '_use_tesseract', False) else "paddleocr"
                else:
                    expert_output = self.pool.run_multi_expert([ExpertID.C], crop, region.bbox)
            else:
                expert_output = self.pool.run_multi_expert(decision.expert_ids, crop, region.bbox)

            # Stage 5
            region = assemble_provenance(region, expert_output, decision, routing_vector, doc_id, page_no)
            processed_regions.append(region)
            all_word_tokens.extend(region.word_tokens)

            # FIX-BUGFIX-5: use shared helper instead of inline append
            self._record_routing(routing_log, region, routing_vector,
                                  decision, expert_output, decision.router_type)  # FIX-BUGFIX-4
            _stage1_consumed += 1  # FIX-BUGFIX-8: normal path

        # Quality Report
        # FIX-BUGFIX-8: reconciliation — compare Stage-1 count vs consumed count
        # (splits produce N processed_regions from 1 Stage-1 region, so we track
        # consumption not output count)
        if len(regions) != _stage1_consumed:
            logger.warning("  Page %d region count mismatch: Stage-1 detected %d, "
                           "consumed %d",
                           page_no, len(regions), _stage1_consumed)
        n_hw = sum(1 for r in processed_regions if r.region_class == RegionClass.HANDWRITING)
        n_pr = sum(1 for r in processed_regions if r.region_class == RegionClass.PRINTED_TEXT)
        n_total = max(len(processed_regions), 1)
        n_low_conf = sum(1 for wt in all_word_tokens if getattr(wt, "confidence", 1.0) < 0.5)

        quality_report = QualityReport(
            page_quality_tier=page_quality_tier,
            page_laplacian_variance=page_quality_var,
            pct_handwritten=round(n_hw / n_total, 2),
            pct_printed=round(n_pr / n_total, 2),
            pct_low_confidence=round(n_low_conf / max(len(all_word_tokens), 1), 2),
            total_regions=n_total,
        )

        def _reading_order_key(r: RegionResult) -> tuple:
            return (r.bbox.y_min // 50, r.bbox.x_min)

        page_text = "\n".join(
            r.text for r in sorted(processed_regions, key=_reading_order_key)
            if r.text.strip() and not r.text.startswith("[VISUAL")
        )

        return PageExtractionResult(
            page_number=page_no, width=w, height=h,
            page_text=page_text,
            word_tokens=all_word_tokens,
            region_map=processed_regions,
            routing_log=routing_log,
            quality_report=quality_report,
        )

pipeline = MoEOCRPipeline(layout=layout_detector, pool=expert_pool, vlm_router=_vlm_router)
