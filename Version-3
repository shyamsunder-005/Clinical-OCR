                _major = int(_paddleocr_mod.__version__.split(".")[0])
                self._paddle_v3 = _major >= 3
            except Exception:
                self._paddle_v3 = False

            # FIX-1: Enable GPU when CUDA is available for PaddleOCR
            _use_gpu = torch.cuda.is_available()
            logger.info("Loading Expert B (PaddleOCR PP-OCRv4, v3_api=%s) on %s …",
                        self._paddle_v3, "GPU" if _use_gpu else "CPU")
            _paddle_kwargs = dict(
                use_textline_orientation=True, lang="en",
                use_gpu=_use_gpu,
                show_log=False,
            )
            if not _use_gpu:
                _paddle_kwargs["enable_mkldnn"] = True
                _paddle_kwargs["cpu_threads"] = 4
            self._ocr = PaddleOCR(**_paddle_kwargs)
            self._use_tesseract = False
            logger.info("✓ Expert B loaded (PaddleOCR on %s)", "GPU" if _use_gpu else "CPU")
        except Exception as e:
            logger.warning("PaddleOCR failed (%s). Using Tesseract fallback.", e)
            self._use_tesseract = True
        self._loaded = True

    @staticmethod
    def _parse_paddle_line(line) -> tuple:
        if isinstance(line, (list, tuple)) and len(line) >= 2:
            bbox_pts = line[0]
            rec = line[1]
            if isinstance(rec, (list, tuple)):
                text = rec[0] if len(rec) > 0 else ""
                conf = float(rec[1]) if len(rec) > 1 else 0.0
            else:
                text = str(rec)
                conf = 0.0
            return bbox_pts, text, conf

        bbox_pts = getattr(line, "bbox", [[0, 0], [0, 0], [0, 0], [0, 0]])
        text = str(getattr(line, "text", ""))
        conf = float(getattr(line, "score", 0.0))
        return bbox_pts, text, conf

    def _run_paddle(self, crop: np.ndarray):
        if self._paddle_v3:
            raw = list(self._ocr.predict(crop))
            if not raw:
                return []
            page = raw[0]

            if hasattr(page, "rec_texts"):
                polys  = list(getattr(page, "rec_polys",  []) or [])
                texts  = list(getattr(page, "rec_texts",  []) or [])
                scores = list(getattr(page, "rec_scores", []) or [])
                if texts:
                    return list(zip(polys, texts, scores))

            if isinstance(page, dict):
                polys  = page.get("rec_polys",  page.get("dt_boxes", [])) or []
                texts  = page.get("rec_texts",  page.get("txts",     [])) or []
                scores = page.get("rec_scores", page.get("scores",   [])) or []
                if texts:
                    return list(zip(polys, texts, scores))

            lines = page if isinstance(page, (list, tuple)) else []
        else:
            raw = self._ocr.ocr(crop)
            lines = raw[0] if (raw and raw[0]) else []

        result = []
        for line in lines:
            try:
                bbox_pts, text, conf = self._parse_paddle_line(line)
                result.append((bbox_pts, text, conf))
            except Exception:
                continue
        return result

    def recognize(self, crop: np.ndarray, bbox: BoundingBox) -> ExpertOutput:
        t0 = time.perf_counter()
        self.load()

        if self._use_tesseract:
            return self._tesseract_fallback(crop, bbox, t0)

        try:
            lines = self._run_paddle(crop)
        except Exception as e:
            logger.warning("PaddleOCR inference failed (%s). Tesseract fallback.", e)
            return self._tesseract_fallback(crop, bbox, t0)

        texts = []
        word_tokens = []
        confidences = []

        for line_bbox_pts, text, conf in lines:
            if text.strip():
                texts.append(text.strip())
                confidences.append(conf)
                xs = [p[0] for p in line_bbox_pts]
                ys = [p[1] for p in line_bbox_pts]
                word_bb = BoundingBox(
                    x=bbox.x + int(min(xs)),
                    y=bbox.y + int(min(ys)),
                    w=int(max(xs) - min(xs)),
                    h=int(max(ys) - min(ys)),
                )
                for w_tok in text.strip().split():
                    word_tokens.append(WordToken(
                        word=w_tok, bbox=word_bb,
                        confidence=conf, expert_id=self.expert_id,
                    ))

        full_text = " ".join(texts)
        avg_conf = float(np.mean(confidences)) if confidences else 0.0
        elapsed = (time.perf_counter() - t0) * 1000

        return ExpertOutput(
            raw_text=full_text,
            word_tokens=word_tokens,
            char_confidence_mean=avg_conf,
            word_confidence_mean=avg_conf,
            expert_id=self.expert_id,
            inference_time_ms=elapsed,
        )

    def _tesseract_fallback(self, crop: np.ndarray,
                              bbox: BoundingBox, t0: float) -> ExpertOutput:
        import pytesseract
        enhanced = enhance_clahe(crop)
        pil = Image.fromarray(
            cv2.cvtColor(enhanced, cv2.COLOR_GRAY2RGB) if len(enhanced.shape) == 2
            else cv2.cvtColor(enhanced, cv2.COLOR_BGR2RGB)
        )
        data = pytesseract.image_to_data(pil, config=config.TESSERACT_CONFIG,
                                          output_type=pytesseract.Output.DICT)
        texts = []
        word_tokens = []
        confidences = []
        for i, word in enumerate(data["text"]):
            if word.strip() and int(data["conf"][i]) > 0:
                conf = int(data["conf"][i]) / 100.0
                texts.append(word.strip())
                confidences.append(conf)
                word_tokens.append(WordToken(
                    word=word.strip(),
                    bbox=BoundingBox(
                        x=bbox.x + data["left"][i],
                        y=bbox.y + data["top"][i],
                        w=data["width"][i], h=data["height"][i],
                    ),
                    confidence=conf,
                    expert_id=ExpertID.TESSERACT,
                ))

        full_text = " ".join(texts)
        avg_conf = float(np.mean(confidences)) if confidences else 0.0
        # FIX-NEW-4: Cap Tesseract confidence so it never beats VLM/TrOCR in fusion
        avg_conf = min(avg_conf, 0.42)
        elapsed = (time.perf_counter() - t0) * 1000
        return ExpertOutput(
            raw_text=full_text, word_tokens=word_tokens,
            char_confidence_mean=avg_conf, word_confidence_mean=avg_conf,
            expert_id=ExpertID.TESSERACT if self._use_tesseract else self.expert_id,
            inference_time_ms=elapsed,
        )

print("✓ Expert B (PaddleOCR / Tesseract fallback) defined")

