class ExpertC_Donut(OCRExpert):
    expert_id = ExpertID.C

    def __init__(self):
        self._model = None
        self._processor = None

    def load(self):
        if self._loaded:
            return
        self._task_prompt = None
        try:
            from transformers import DonutProcessor, VisionEncoderDecoderModel
            logger.info("Loading Expert C (Donut): %s → %s",
                         config.DONUT_MODEL, config.DEVICE_LIGHT)
            self._processor = DonutProcessor.from_pretrained(config.DONUT_MODEL)
            self._model = VisionEncoderDecoderModel.from_pretrained(config.DONUT_MODEL)
            self._model.config.tie_word_embeddings = False
            self._model.decoder.config.tie_word_embeddings = False
            self._model.eval().to(config.DEVICE_LIGHT)

            _special = self._processor.tokenizer.all_special_tokens
            _task_candidates = [t for t in _special if t.startswith("<s_") and t != "<s>"]
            if _task_candidates:
                self._task_prompt = _task_candidates[0]
                logger.info("✓ Expert C: auto-detected task token: %s", self._task_prompt)
            else:
                logger.warning("Expert C: no <s_*> task token found. Unavailable.")
                self._model = None

            self._loaded = True
            if self._model is not None:
                logger.info("✓ Expert C loaded on %s", config.DEVICE_LIGHT)
        except Exception as e:
            logger.warning("Donut load failed (%s). Expert C unavailable.", e)
            self._model = None
            self._loaded = True

    def recognize(self, crop: np.ndarray, bbox: BoundingBox) -> ExpertOutput:
        t0 = time.perf_counter()
        self.load()

        if self._model is None or self._task_prompt is None:
            return ExpertOutput(expert_id=self.expert_id,
                                raw_text="[Expert C unavailable]")

        pil = self._to_pil(crop)
        task_prompt = self._task_prompt
        decoder_input_ids = self._processor.tokenizer(
            task_prompt, add_special_tokens=False,
            return_tensors="pt").input_ids.to(config.DEVICE_LIGHT)

        pixel_values = self._processor(pil, return_tensors="pt").pixel_values.to(config.DEVICE_LIGHT)

        from transformers import GenerationConfig
        _gen_cfg = GenerationConfig(
            max_length=self._model.decoder.config.max_position_embeddings,
            pad_token_id=self._processor.tokenizer.pad_token_id,
            eos_token_id=self._processor.tokenizer.eos_token_id,
            bad_words_ids=[[self._processor.tokenizer.unk_token_id]],
            do_sample=False,
        )
        with torch.no_grad():
            out = self._model.generate(
                pixel_values,
                decoder_input_ids=decoder_input_ids,
                generation_config=_gen_cfg,
                return_dict_in_generate=True,
                output_scores=True,  # FIX-BUGFIX-3: compute real confidence
            )

        text = self._processor.batch_decode(out.sequences)[0]
        import re as _re_g
        text = text.replace(task_prompt, "").replace("</s>", "")
        text = _re_g.sub(r'<[^>]+>', ' ', text)
        clean_text = _re_g.sub(r'\s+', ' ', text).strip()

        # FIX-BUGFIX-3: Real token-level confidence instead of hardcoded 0.6
        if hasattr(out, 'scores') and out.scores:
            probs = [torch.softmax(s, dim=-1).max().item() for s in out.scores]
            conf = float(np.mean(probs)) if probs else 0.5
        else:
            conf = 0.5

        # FIX-BUGFIX-3: Garbage-ratio heuristic (mirrors Expert D's _garbage_ratio)
        words = clean_text.split()
        n_words = len(words)
        if n_words > 0:
            _garbage_count = sum(
                1 for w in words
                if _re_g.fullmatch(r'[^a-zA-Z0-9./\-+%]{2,}', w)
            )
            _repeat_count = sum(
                1 for i in range(1, n_words) if words[i] == words[i - 1]
            )
            _junk_ratio = (_garbage_count + _repeat_count) / n_words
            if _junk_ratio > 0.40:
                conf *= 0.30  # FIX-BUGFIX-3: heavy penalty for junk output

        elapsed = (time.perf_counter() - t0) * 1000
        return ExpertOutput(
            raw_text=clean_text,
            word_tokens=self._text_to_word_tokens(clean_text, self.expert_id, conf, bbox),
            char_confidence_mean=conf,
            word_confidence_mean=conf,
            expert_id=self.expert_id,
            inference_time_ms=elapsed,
        )

print("✓ Expert C (Donut) defined")

