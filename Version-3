class OCRExpert(ABC):
    expert_id: ExpertID = ExpertID.TESSERACT
    _loaded: bool = False

    @abstractmethod
    def recognize(self, crop: np.ndarray,
                  bbox: BoundingBox) -> ExpertOutput:
        ...

