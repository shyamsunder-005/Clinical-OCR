import hashlib
import concurrent.futures

class ExpertRegistry:
    """Plugin-based expert registry to decouple pool from hardcoded implementations."""
    def __init__(self):
        self._experts: Dict[ExpertID, OCRExpert] = {}

    def register(self, expert: OCRExpert):
        self._experts[expert.expert_id] = expert
        logger.info("Registered Expert %s (%s)",
                     expert.expert_id.value, expert.__class__.__name__)

    def get(self, expert_id: ExpertID) -> Optional[OCRExpert]:
        return self._experts.get(expert_id)

    def available_ids(self) -> set:
        return set(self._experts.keys()) | {ExpertID.TESSERACT}

class ExpertPool:
    def __init__(self):
        self.registry = ExpertRegistry()
        self._region_cache: Dict[str, ExpertOutput] = {}
        self._init_experts()

    def _init_experts(self):
        self.registry.register(ExpertA_TrOCR())
        self.registry.register(ExpertB_PaddleOCR())
        self.registry.register(ExpertC_Donut())
        self.registry.register(ExpertD_ChandraOCR())

    @property
    def available_experts(self) -> set:
        return self.registry.available_ids()

    def _cache_key(self, expert_id: ExpertID, crop: np.ndarray) -> str:
        """SHA-256 keyed region cache."""
        img_bytes = crop.tobytes()
        h = hashlib.sha256(f"{expert_id.value}:".encode("utf-8") + img_bytes).hexdigest()
        return h

    @staticmethod
    def calibrate_confidence(conf: float, expert_id: ExpertID) -> float:
        """Calibrate raw softmax confidence from experts using temperature scaling."""
        TEMPERATURE = {
            ExpertID.A: 1.10,  # TrOCR tends to be overconfident
            ExpertID.B: 1.00,  # PaddleOCR
            ExpertID.C: 1.05,  # Donut
            ExpertID.D: 0.88,  # Chandra OCR 2 tends to be underconfident
            ExpertID.TESSERACT: 1.30, # Heavy penalty
        }
        temp = TEMPERATURE.get(expert_id, 1.0)
        if temp <= 0: return conf
        if conf <= 0.0: return 0.0
        if conf >= 1.0: return 1.0
        return float(conf ** temp)

    def run_expert(self, expert_id: ExpertID, crop: np.ndarray, bbox: BoundingBox, retries: int = 1) -> ExpertOutput:
        """Execute single expert with cache, retry, and fallback."""
        key = self._cache_key(expert_id, crop)
        if key in self._region_cache:
            out = self._region_cache[key]
            out_copy = ExpertOutput(**out.model_dump())
            for wt in out_copy.word_tokens:
                wt.cache_hit = True
            return out_copy

        if expert_id == ExpertID.TESSERACT:
            fb = ExpertB_PaddleOCR()
            fb._use_tesseract = True
            fb._loaded = True
            res = fb.recognize(crop, bbox)
            self._region_cache[key] = res
            return res

        expert = self.registry.get(expert_id)
        if expert is None:
            logger.warning("Expert %s not registered. Falling back to B.", expert_id)
            return self.run_expert(ExpertID.B, crop, bbox)

        last_err = None
        for attempt in range(retries + 1):
            try:
                res = expert.recognize(crop, bbox)
                self._region_cache[key] = res
                return res
            except Exception as e:
                last_err = e
                logger.warning("Expert %s failed (attempt %d).", expert_id, attempt + 1)
        
        logger.error("Expert %s exhausted retries (%s). Falling back to B.", expert_id, last_err)
        return self.run_expert(ExpertID.B, crop, bbox)

    @staticmethod
    def _is_valid_output(out: ExpertOutput) -> bool:  # FIX-BUGFIX-2
        """Shared validity check — False for empty or sentinel outputs."""
        if not out.raw_text.strip():
            return False
        if out.raw_text.startswith("[Expert"):  # FIX-BUGFIX-2: single source of truth
            return False
        return True

    def run_multi_expert(self, expert_ids: List[ExpertID], crop: np.ndarray, bbox: BoundingBox) -> ExpertOutput:
        """Asynchronous multi-expert execution via ThreadPoolExecutor."""
        if not expert_ids:
            return ExpertOutput(raw_text="[VISUAL — no OCR]", expert_id=ExpertID.TESSERACT)
        
        if len(expert_ids) == 1:
            result = self.run_expert(expert_ids[0], crop, bbox)
            # FIX-BUGFIX-2: validate single-expert output; fall back to B if invalid
            if not self._is_valid_output(result):
                logger.warning("Single-expert %s invalid output — falling back to B", expert_ids[0].value)
                result = self.run_expert(ExpertID.B, crop, bbox)
            # FIX-BUGFIX-7: calibrate even single-expert outputs
            result.word_confidence_mean = self.calibrate_confidence(
                result.word_confidence_mean, result.expert_id)
            return result

        outputs = []
        with concurrent.futures.ThreadPoolExecutor(max_workers=min(4, len(expert_ids))) as executor:
            future_to_eid = {executor.submit(self.run_expert, eid, crop, bbox): eid for eid in expert_ids}
            for future in concurrent.futures.as_completed(future_to_eid):
                try:
                    out = future.result()
                    if self._is_valid_output(out):  # FIX-BUGFIX-2: use shared helper
                        outputs.append(out)
                except Exception as e:
                    logger.error("Multi-expert execution error: %s", e)

        if not outputs:
            return ExpertOutput(expert_id=expert_ids[0])

        # FIX-BUGFIX-7: calibrate ALL outputs immediately, before any branching,
        # so confidence values are comparable regardless of candidate count.
        for out in outputs:
            out.word_confidence_mean = self.calibrate_confidence(out.word_confidence_mean, out.expert_id)

        if len(outputs) == 1:
            return outputs[0]  # FIX-BUGFIX-7: now calibrated

        PRIORITY = {ExpertID.D: 3, ExpertID.A: 2, ExpertID.C: 1, ExpertID.B: 1, ExpertID.TESSERACT: 0}

        valid = [o for o in outputs if o.word_confidence_mean > 0.20 and len(o.raw_text.strip()) > 3]
        if not valid:
            return max(outputs, key=lambda o: len(o.raw_text))

        premium = [o for o in valid if PRIORITY.get(o.expert_id, 0) >= 3 and o.word_confidence_mean >= 0.25]
        if premium:
            best = max(premium, key=lambda o: o.word_confidence_mean)
        else:
            best = max(valid, key=lambda o: (PRIORITY.get(o.expert_id, 0), o.word_confidence_mean))

        best.inference_time_ms = sum(o.inference_time_ms for o in outputs)
        return best

    def run_probe(self, crop: np.ndarray, bbox: BoundingBox) -> ExpertOutput:
        result = self.run_expert(ExpertID.B, crop, bbox)
        if result.expert_id == ExpertID.TESSERACT:
            result.word_confidence_mean = min(result.word_confidence_mean, 0.42)
            result.char_confidence_mean = min(result.char_confidence_mean, 0.42)
        return result

    def preload_all(self):
        if not config.CO_RESIDENT:
            logger.info("Not co-resident mode — experts load on demand.")
            return
        logger.info("Pre-loading all experts (co-resident dual T4) …")
        for eid in self.registry.available_ids():
            if eid == ExpertID.TESSERACT: continue
            expert = self.registry.get(eid)
            try:
                expert.load()
            except Exception as e:
                logger.warning("Failed to pre-load Expert %s: %s", eid, e)
        logger.info("✓ Expert pre-loading complete")

expert_pool = ExpertPool()
print(f"✓ Expert Pool ready ({len(expert_pool.registry.available_ids()) - 1} experts registered)")

