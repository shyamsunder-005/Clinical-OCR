import re
import json as _json_module
from abc import ABC, abstractmethod
CHECKBOX_PATTERN = re.compile(r"YES\s*/?\s*NO", re.IGNORECASE)

# ── VisionLanguageRouter Interface ──────────────────────────────────

class VisionLanguageRouter(ABC):
    """Generic VLM router interface. SmolVLM-500M is the default implementation.
    Any conforming VLM that takes an image crop + routing vector and returns a
    RoutingDecision can be plugged in via this interface."""

    @abstractmethod
    def load(self): ...

    @abstractmethod
    def route(self, crop: np.ndarray, rv: "RoutingVector",
              available_experts: set) -> "RoutingDecision": ...

    @abstractmethod
    def is_available(self) -> bool: ...

    def unload(self):
        """Optional: free GPU memory."""
        pass


