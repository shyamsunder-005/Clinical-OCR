class ExpertD_ChandraOCR(OCRExpert):
    expert_id = ExpertID.D

    def __init__(self):
        self._model = None
        self._processor = None

    def is_available(self) -> bool:
        try:
            import transformers
            return True
        except ImportError:
            return False

    def load(self):
        if self._loaded and self._model is not None:
            return
        try:
            # FIX-BUGFIX-6: same import fallback chain as SmolVLM router
            try:
                from transformers import AutoProcessor, AutoModelForImageTextToText as _DAutoModel, BitsAndBytesConfig
            except ImportError:
                from transformers import AutoProcessor, AutoModelForVision2Seq as _DAutoModel, BitsAndBytesConfig
            logger.info("Loading Expert D (Chandra OCR 2): %s → %s (4-bit)",
                         config.CHANDRA_OCR_MODEL, config.DEVICE_HEAVY)
            
            self._processor = AutoProcessor.from_pretrained(config.CHANDRA_OCR_MODEL)
            qconfig = BitsAndBytesConfig(load_in_4bit=True)
            self._model = _DAutoModel.from_pretrained(
                config.CHANDRA_OCR_MODEL,
                device_map=config.DEVICE_HEAVY,
                quantization_config=qconfig,
                torch_dtype=torch.float16,
                low_cpu_mem_usage=True,
            )
            self._model.eval()
            self._loaded = True
            logger.info("✓ Expert D loaded (4-bit on %s)", config.DEVICE_HEAVY)
        except Exception as e:
            logger.warning("Chandra OCR 2 load failed (%s). Expert D unavailable.", e)
            self._loaded = True
            self._model = None

    def unload(self):
        if self._model is not None and not config.CO_RESIDENT:
            import gc
            del self._model
            del self._processor
            self._model = None
            self._processor = None
            gc.collect()
            torch.cuda.empty_cache()
        self._loaded = False

    def recognize(self, crop: np.ndarray, bbox: BoundingBox) -> ExpertOutput:
        t0 = time.perf_counter()
        self.load()

        if self._model is None:
            return ExpertOutput(expert_id=self.expert_id,
                                raw_text="[Expert D unavailable]")

        pil = self._to_pil(crop)
        
        prompt = (
            "Read all text in this image exactly as written. "
            "Preserve structure, tables, and line breaks."
        )
        
        messages = [{"role": "user", "content": [
            {"type": "image"}, {"type": "text", "text": prompt}
        ]}]
        text_prompt = self._processor.apply_chat_template(
            messages, tokenize=False, add_generation_prompt=True)
            
        with _gpu_lock:
            inputs = self._processor(
                text=[text_prompt], images=[pil],
                return_tensors="pt", padding=True,
            ).to(self._model.device)

            with torch.no_grad():
                out = self._model.generate(
                    **inputs,
                    max_new_tokens=512,
                    do_sample=False,
                    repetition_penalty=1.1,
                    pad_token_id=self._processor.tokenizer.eos_token_id,
                )
            generated = out[0][inputs["input_ids"].shape[1]:]
            text = self._processor.decode(generated, skip_special_tokens=True).strip()

        words = text.split()
        n_words = len(words)
        if n_words == 0:
            conf = 0.0
        else:
            import re as _re_d
            _garbage_ratio = sum(
                1 for w in words
                if _re_d.fullmatch(r'[^a-zA-Z0-9./\-+%]{2,}', w)
            ) / n_words
            conf = 0.20 if _garbage_ratio > 0.40 else 0.72

        elapsed = (time.perf_counter() - t0) * 1000
        return ExpertOutput(
            raw_text=text,
            word_tokens=self._text_to_word_tokens(text, self.expert_id, conf, bbox),
            char_confidence_mean=conf,
            word_confidence_mean=conf,
            expert_id=self.expert_id,
            inference_time_ms=elapsed,
        )

