# Simplified prompt — SmolVLM-500M can't reliably produce complex JSON.
# We ask 3 short classification questions and map answers to experts in code.
_SMOLVLM_ROUTER_PROMPT = (
    "Look at this image from a medical document.\n"
    "Answer with ONLY a JSON object, nothing else:\n"
    '{"type":"HANDWRITING","readability":"HARD","layout":"MULTI_LINE"}\n\n'
    "type: HANDWRITING or PRINTED\n"
    "readability: EASY, MEDIUM, or HARD\n"
    "layout: SINGLE_LINE, MULTI_LINE, or TABLE"
)

# Even simpler retry prompt if the first attempt fails to parse
_SMOLVLM_RETRY_PROMPT = (
    "Is the text in this image handwritten or printed? "
    "Answer: HANDWRITING or PRINTED"
)

# Keyword sets for fuzzy parsing when JSON extraction fails
_KW_HANDWRITING = {"handwriting", "handwritten", "cursive", "hand", "written"}
_KW_PRINTED = {"printed", "print", "typed", "type", "digital", "machine"}
_KW_HARD = {"hard", "difficult", "messy", "poor", "low", "degraded", "blurry", "dense"}
_KW_EASY = {"easy", "clean", "clear", "neat", "good", "high", "simple", "legible"}
_KW_TABLE = {"table", "grid", "form", "structured", "column", "row", "cell"}


def _pil_from_crop(crop: np.ndarray) -> "Image.Image":
    """Convert BGR/grayscale numpy crop to RGB PIL Image."""
    from PIL import Image
    if len(crop.shape) == 2:
        return Image.fromarray(cv2.cvtColor(crop, cv2.COLOR_GRAY2RGB))
    return Image.fromarray(cv2.cvtColor(crop, cv2.COLOR_BGR2RGB))


def _safe_float(val, default: float = 0.5) -> float:
    """Safely convert a value to float, handling strings like '0.0-1.0'."""
    if isinstance(val, (int, float)):
        return float(val)
    if isinstance(val, str):
        try:
            return float(val)
        except ValueError:
            pass
        import re as _re_sf
        m = _re_sf.search(r'(\d+\.?\d*)', val)
        if m:
            return float(m.group(1))
    return default


def _map_vlm_to_experts(content_type: str, readability: str, layout: str,
                         crop_area_px: int,
                         available_experts: set) -> List[ExpertID]:
    """Map simplified VLM classification to expert IDs.
    This is the core routing logic that was previously baked into the prompt."""
    experts = []

    if layout == "TABLE":
        experts = [ExpertID.D, ExpertID.B]
    elif content_type == "PRINTED":
        if readability == "HARD":
            experts = [ExpertID.D, ExpertID.B]
        else:
            experts = [ExpertID.B]
    else:  # HANDWRITING
        if readability == "EASY" and crop_area_px < 150_000:
            experts = [ExpertID.A]
        elif readability == "MEDIUM":
            if crop_area_px > 150_000:
                experts = [ExpertID.D, ExpertID.A]
            else:
                experts = [ExpertID.A, ExpertID.D]
        else:  # HARD or large area
            experts = [ExpertID.D, ExpertID.A]

    # Filter to available, fallback to B/TESSERACT
    selected = [e for e in experts if e in available_experts]
    if not selected:
        for fb in [ExpertID.B, ExpertID.TESSERACT]:
            if fb in available_experts:
                return [fb]
        return [ExpertID.TESSERACT]
    return selected


def _fuzzy_parse_vlm(raw: str) -> Optional[dict]:
    """Extract classification from SmolVLM output, tolerating malformed responses.
    Tries JSON first, then keyword matching as fallback."""
    import re as _re_fp

    # Attempt 1: standard JSON extraction
    json_match = _re_fp.search(r'\{[^{}]*\}', raw, _re_fp.DOTALL)
    if json_match:
        try:
            rec = _json_module.loads(json_match.group())
            result = {}
            # Normalize type
            _t = str(rec.get("type", "")).upper()
            result["type"] = "HANDWRITING" if "HAND" in _t else "PRINTED"
            # Normalize readability
            _r = str(rec.get("readability", rec.get("difficulty", ""))).upper()
            if "HARD" in _r or "DIFF" in _r:
                result["readability"] = "HARD"
            elif "EASY" in _r or "CLEAN" in _r:
                result["readability"] = "EASY"
            else:
                result["readability"] = "MEDIUM"
            # Normalize layout
            _l = str(rec.get("layout", "")).upper()
            if "TABLE" in _l or "GRID" in _l:
                result["layout"] = "TABLE"
            elif "SINGLE" in _l:
                result["layout"] = "SINGLE_LINE"
            else:
                result["layout"] = "MULTI_LINE"
            return result
        except (ValueError, KeyError):
            pass

    # Attempt 2: keyword-based fuzzy extraction from raw text
    raw_lower = raw.lower()
    tokens = set(raw_lower.split())

    # Determine type
    hw_hits = len(tokens & _KW_HANDWRITING)
    pr_hits = len(tokens & _KW_PRINTED)
    if hw_hits == 0 and pr_hits == 0:
        return None  # can't extract anything meaningful
    content_type = "HANDWRITING" if hw_hits >= pr_hits else "PRINTED"

    # Determine readability
    hard_hits = len(tokens & _KW_HARD)
    easy_hits = len(tokens & _KW_EASY)
    if hard_hits > easy_hits:
        readability = "HARD"
    elif easy_hits > hard_hits:
        readability = "EASY"
    else:
        readability = "MEDIUM"

    # Determine layout
    table_hits = len(tokens & _KW_TABLE)
    layout = "TABLE" if table_hits >= 2 else "MULTI_LINE"

    return {"type": content_type, "readability": readability, "layout": layout}


class SmolVLMRouter(VisionLanguageRouter):
    """SmolVLM-500M-Instruct as dedicated VLM visual router.
    Loaded 4-bit on CUDA:1 (~1 GB VRAM). Analyses image crops and returns
    a hard routing decision mapping to Expert A/B/C/D.
    
    This model performs ROUTING ONLY, not OCR. It is not an expert.
    """

    def __init__(self):
        self._model = None
        self._processor = None
        self._loaded = False

    def is_available(self) -> bool:
        # FIX-BUGFIX-6: try both auto-class names
        try:
            from transformers import AutoProcessor, AutoModelForImageTextToText
            return True
        except ImportError:
            pass
        try:
            from transformers import AutoProcessor, AutoModelForVision2Seq
            return True
        except ImportError:
            import transformers
            logger.warning("SmolVLM unavailable: transformers %s has neither "
                           "AutoModelForImageTextToText nor AutoModelForVision2Seq",
                           transformers.__version__)
            return False

    def load(self):
        if self._loaded:
            return
        try:
            # FIX-BUGFIX-6: try AutoModelForImageTextToText first, fall back
            try:
                from transformers import AutoProcessor, AutoModelForImageTextToText as _VLMAutoModel, BitsAndBytesConfig
            except ImportError:
                from transformers import AutoProcessor, AutoModelForVision2Seq as _VLMAutoModel, BitsAndBytesConfig

            logger.info("Loading SmolVLM-500M Router: %s → cuda:1 (4-bit)",
                         config.VLM_ROUTER_MODEL)
            self._processor = AutoProcessor.from_pretrained(config.VLM_ROUTER_MODEL)
            qconfig = BitsAndBytesConfig(load_in_4bit=True)
            self._model = _VLMAutoModel.from_pretrained(
                config.VLM_ROUTER_MODEL,
                device_map="cuda:1",
                quantization_config=qconfig,
                low_cpu_mem_usage=True,
            )
            self._model.eval()
            self._loaded = True
            logger.info("✓ SmolVLM-500M Router loaded (4-bit, cuda:1)")
        except Exception as e:
            # FIX-BUGFIX-6: log installed version for diagnosability
            _ver = "unknown"
            try:
                import transformers; _ver = transformers.__version__
            except Exception:
                pass
            logger.warning("SmolVLM Router load failed (transformers=%s, %s). "
                           "Rule-based fallback only.", _ver, e)
            self._loaded = True
            self._model = None

    def unload(self):
        if self._model is not None:
            import gc
            del self._model
            del self._processor
            self._model = None
            self._processor = None
            gc.collect()
            torch.cuda.empty_cache()
        self._loaded = False

    def _generate(self, pil, prompt_text: str, max_tokens: int = 50) -> str:
        """Run SmolVLM inference and return raw decoded text."""
        messages = [{"role": "user", "content": [
            {"type": "image"}, {"type": "text", "text": prompt_text}
        ]}]
        text_prompt = self._processor.apply_chat_template(
            messages, tokenize=False, add_generation_prompt=True)

        with _gpu_lock:
            inputs = self._processor(
                text=[text_prompt], images=[pil],
                return_tensors="pt", padding=True,
            ).to(self._model.device)

            with torch.no_grad():
                out = self._model.generate(
                    **inputs,
                    max_new_tokens=max_tokens,
                    do_sample=False,
                )
            generated = out[0][inputs["input_ids"].shape[1]:]
            return self._processor.decode(generated, skip_special_tokens=True).strip()

    def route(self, crop: np.ndarray, rv: "RoutingVector",
              available_experts: set) -> "RoutingDecision":
        """Run SmolVLM on the crop to determine which expert(s) to invoke.
        Uses simplified 3-question prompt with fuzzy parsing and retry.
        Falls back to route_region_fast() only if both attempts fail."""
        self.load()

        if self._model is None:
            return route_region_fast(rv, available_experts)

        try:
            # Downscale to max 512px edge — router only needs to *see* the image
            _rh, _rw = crop.shape[:2]
            _max_edge = config.VLM_ROUTER_MAX_EDGE
            if max(_rh, _rw) > _max_edge:
                _scale = _max_edge / max(_rh, _rw)
                crop_resized = cv2.resize(
                    crop, (int(_rw * _scale), int(_rh * _scale)),
                    interpolation=cv2.INTER_AREA)
            else:
                crop_resized = crop

            pil = _pil_from_crop(crop_resized)

            # Attempt 1: structured 3-question prompt
            raw = self._generate(pil, _SMOLVLM_ROUTER_PROMPT, max_tokens=50)
            parsed = _fuzzy_parse_vlm(raw)

            # Attempt 2: ultra-simple fallback prompt if first parse failed
            if parsed is None:
                logger.info("    ↳ SmolVLM first attempt unparseable (%s), retrying simple prompt",
                             raw[:60])
                raw2 = self._generate(pil, _SMOLVLM_RETRY_PROMPT, max_tokens=20)
                raw_combined = raw + " " + raw2
                parsed = _fuzzy_parse_vlm(raw_combined)

            if parsed is None:
                raise ValueError(f"Both VLM attempts unparseable: {raw[:80]}")

            content_type = parsed["type"]
            readability = parsed["readability"]
            layout = parsed["layout"]

            expert_ids = _map_vlm_to_experts(
                content_type, readability, layout,
                rv.crop_area_px, available_experts)

            rationale = (
                f"SmolVLM Router [{content_type} | {readability} | {layout}]"
            )
            logger.info("    ↳ SmolVLM Router → %s (%s, %s, %s)",
                         [e.value for e in expert_ids],
                         content_type, readability, layout)

            return RoutingDecision(
                expert_ids=expert_ids,
                rationale=rationale,
                probabilities={
                    "router_confidence": 0.80,
                },
                metadata={"type": content_type, "readability": readability,
                          "layout": layout, "raw": raw[:100],
                          "router_type": "smolvlm"},
                router_type="smolvlm",  # FIX-BUGFIX-4
            )

        except Exception as e:
            logger.warning("SmolVLM Router failed (%s). Rule-based fallback.", e)
            return route_region_fast(rv, available_experts)


# ── Rule-based Fast Router ──────────────────────────────────────────

def route_region_fast(rv: RoutingVector,
                      available_experts: set) -> RoutingDecision:
    """Tier 1: Deterministic rule-based MoE router [P26][P27].
    All expert references updated for v3.0: D=ChandraOCR, C=Donut.
    E/F/G removed from routing table."""
    rc = rv.region_class
    qt = rv.quality_tier

    def pick(experts: List[ExpertID], rationale: str) -> RoutingDecision:
        selected = [e for e in experts if e in available_experts]
        if not selected:
            for fb in [ExpertID.B, ExpertID.TESSERACT]:
                if fb in available_experts:
                    selected = [fb]
                    break
            if not selected:
                selected = [ExpertID.TESSERACT]
        return RoutingDecision(expert_ids=selected, rationale=rationale,
                               metadata={"router_type": "rule_based"},
                               router_type="rule_based")  # FIX-BUGFIX-4

    # ── Indian/Indic script override → Chandra (multilingual) ─────
    if rv.script_flag:
        return pick([ExpertID.D, ExpertID.B],
                     "Indian script detected (>20% non-Latin) → Chandra OCR 2 [P14]")

    # ── Checkbox YES/NO routing ────────────────────────────────────
    if rv.probe_text and CHECKBOX_PATTERN.search(rv.probe_text):
        return pick([ExpertID.D, ExpertID.B],
                     "YES/NO checkbox detected → Chandra OCR 2 [P11]")

    # ── Escalation on low probe confidence ─────────────────────────
    threshold = config.get_escalation_threshold(rc.value)
    if rv.probe_confidence < threshold:
        if rv.probe_confidence == 0.0:
            if rc == RegionClass.PRINTED_TEXT and qt == QualityTier.HIGH:
                return pick([ExpertID.D],
                             "Zero-confidence PRINTED+HIGH → Chandra OCR 2 [FIX-9]")
            elif rc == RegionClass.HANDWRITING:
                return pick([ExpertID.A],
                             "Zero-confidence HANDWRITING → TrOCR [FIX-9]")
            elif qt == QualityTier.LOW:
                return pick([ExpertID.D],
                             "Zero-confidence LOW quality → Chandra OCR 2 [FIX-9]")
        return pick([ExpertID.D, ExpertID.B],
                     f"Probe conf {rv.probe_confidence:.2f} < {threshold:.2f} — escalate to Chandra [P12]")

    # ── Main routing table ───────────────────────────────────────────
    if rc == RegionClass.TABLE:
        return pick([ExpertID.D, ExpertID.B],
                     "TABLE region → Chandra OCR 2 (structural) [P11]")

    if rc == RegionClass.FORM_FIELD:
        return pick([ExpertID.C, ExpertID.B],
                     "FORM_FIELD → Donut (templates) or PaddleOCR [P17]")

    if rc == RegionClass.HANDWRITING:
        if rv.crop_area_px > 150_000:
            return pick([ExpertID.D], "HANDWRITING large crop → Chandra OCR 2 [FIX-NEW-1]")
        elif rv.crop_area_px >= 20_000:
            return pick([ExpertID.A], "HANDWRITING medium crop → TrOCR [FIX-NEW-1]")
        else:
            return pick([ExpertID.B], "HANDWRITING tiny crop → PaddleOCR probe [FIX-NEW-1]")

    if rc == RegionClass.PRINTED_TEXT:
        if qt == QualityTier.HIGH:
            experts = [ExpertID.B]
            # FIX-BUGFIX-3: Removed ExpertID.C from PRINTED_TEXT routing —
            # Donut is for structured forms, not arbitrary printed text.
            # Real FORM_FIELD detection is out of scope for this fix pass.
            return pick(experts,
                         f"PRINTED + HIGH → PaddleOCR (conf={rv.probe_confidence:.2f}) [P9]")
        elif qt == QualityTier.MEDIUM:
            experts = [ExpertID.B]
            # FIX-BUGFIX-3: Removed ExpertID.C — same rationale as HIGH
            return pick(experts,
                         f"PRINTED + MEDIUM → PaddleOCR (conf={rv.probe_confidence:.2f}) [P9]")
        else:
            return pick([ExpertID.D, ExpertID.B],
                         "PRINTED + LOW → Chandra OCR 2 + PaddleOCR [P11]")

    if rv.complexity_score > 0.6:
        return pick([ExpertID.D, ExpertID.B],
                     f"MIXED_COMPLEX (complexity={rv.complexity_score:.2f}) → Chandra [P11]")

    if rc in (RegionClass.VISUAL_ELEMENT, RegionClass.FIGURE,
              RegionClass.STAMP, RegionClass.SIGNATURE):
        return RoutingDecision(
            expert_ids=[],
            rationale=f"Visual element ({rc.value}) — skip OCR",
            metadata={"router_type": "rule_based"},
        )

    return pick([ExpertID.B, ExpertID.TESSERACT],
                 f"Default route for {rc.value} + {qt.value}")


def _fast_route_is_certain(rv: RoutingVector) -> bool:
    """Check if the rule-based router can handle this region with certainty,
    or if we should escalate to SmolVLM for visual analysis."""
    if rv.region_class == RegionClass.HANDWRITING:
        if rv.crop_area_px < 20_000 and rv.probe_confidence > 0.85:
            return True
        return False  # Escalate to SmolVLM

    if rv.region_class == RegionClass.PRINTED_TEXT:
        if rv.quality_tier == QualityTier.LOW:
            return False
        if rv.probe_confidence < 0.40:
            return False
        return True

    return True


