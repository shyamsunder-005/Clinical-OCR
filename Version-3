from pydantic import BaseModel, Field as PydField

# ── Enums ────────────────────────────────────────────────────────────

class QualityTier(str, Enum):
    HIGH = "HIGH"
    MEDIUM = "MEDIUM"
    LOW = "LOW"

class RegionClass(str, Enum):
    PRINTED_TEXT = "PRINTED_TEXT"
    HANDWRITING = "HANDWRITING"
    TABLE = "TABLE"
    FIGURE = "FIGURE"
    STAMP = "STAMP"
    SIGNATURE = "SIGNATURE"
    FORM_FIELD = "FORM_FIELD"
    VISUAL_ELEMENT = "VISUAL_ELEMENT"

class SemanticRole(str, Enum):
    HEADER = "HEADER"
    PARAGRAPH = "PARAGRAPH"
    TABLE_CELL = "TABLE_CELL"
    HANDWRITTEN_NOTE = "HANDWRITTEN_NOTE"
    PRINTED_FIELD = "PRINTED_FIELD"
    STAMP_REGION = "STAMP_REGION"
    FIGURE_CAPTION = "FIGURE_CAPTION"

class ExpertID(str, Enum):
    """OCR expert identifiers. Hard routing is deterministic, explainable,
    and clinically auditable. E (Qwen2-VL) removed — VLM is router only."""
    A = "A"          # TrOCR-Large
    B = "B"          # PaddleOCR PP-OCRv5
    C = "C"          # Donut
    D = "D"          # Chandra OCR 2
    TESSERACT = "TESSERACT"  # CPU fallback

# ── Value Objects ────────────────────────────────────────────────────

class BoundingBox(BaseModel):
    x: int = PydField(..., description="Left edge (px)")
    y: int = PydField(..., description="Top edge (px)")
    w: int = PydField(..., description="Width (px)")
    h: int = PydField(..., description="Height (px)")

    @property
    def x_min(self) -> int: return self.x
    @property
    def y_min(self) -> int: return self.y
    @property
    def x_max(self) -> int: return self.x + self.w
    @property
    def y_max(self) -> int: return self.y + self.h

class RoutingVector(BaseModel):
    laplacian_variance: float = 0.0
    blur_score: float = 0.0
    noise_estimate: float = 0.0
    predicted_cer: float = 1.0
    region_class: RegionClass = RegionClass.PRINTED_TEXT
    quality_tier: QualityTier = QualityTier.MEDIUM
    handwriting_score: float = 0.0
    script_flag: bool = False
    complexity_score: float = 0.0
    probe_confidence: float = 0.0
    # FIX 4: probe_text was referenced in route_region() via rv.probe_text but
    # was never declared as a field on RoutingVector, causing AttributeError at
    # runtime whenever the YES/NO checkbox routing branch was reached.
    probe_text: str = ""
    # FIX-NEW-1: Crop area in pixels for area-based routing decisions
    crop_area_px: int = 0

class RoutingDecision(BaseModel):
    expert_ids: List[ExpertID]
    rationale: str
    probabilities: Dict[str, float] = PydField(default_factory=dict)
    metadata: Dict[str, Any] = PydField(default_factory=dict)  # FIX-NEW-13: VLM router JSON
