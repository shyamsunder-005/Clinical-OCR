def run_ablation(file_path: str) -> Dict[str, Any]:
    results: Dict[str, Any] = {}
    images = ingest_document(file_path)
    if not images:
        return results

    page_img = images[0]
    h, w = page_img.shape[:2]
    bb = BoundingBox(x=0, y=0, w=w, h=h)

    # A0: Raw PaddleOCR on full page
    t0 = time.perf_counter()
    a0_out = expert_pool.run_expert(ExpertID.B, page_img, bb)
    results["A0_single_paddleocr"] = {
        "text": a0_out.raw_text[:200],
        "confidence": a0_out.word_confidence_mean,
        "time_ms": (time.perf_counter() - t0) * 1000,
    }

    # A1: Preprocessed + PaddleOCR
    preprocessed, _, _ = preprocess_page(page_img)
    t0 = time.perf_counter()
    prep_3ch = cv2.cvtColor(preprocessed, cv2.COLOR_GRAY2BGR)
    a1_out = expert_pool.run_expert(ExpertID.B, prep_3ch, bb)
    results["A1_preprocessed"] = {
        "text": a1_out.raw_text[:200],
        "confidence": a1_out.word_confidence_mean,
        "time_ms": (time.perf_counter() - t0) * 1000,
    }

    # A4: Full pipeline
    t0 = time.perf_counter()
    full_result = pipeline.process_document(file_path)
    results["A4_full_pipeline"] = {
        "text": get_plain_text(full_result)[:200],
        "time_ms": full_result.processing_time_seconds * 1000,
        "experts_used": {
            e.value: sum(1 for p in full_result.pages
                         for log in p.routing_log
                         if e in log.experts_invoked)
            for e in ExpertID
        },
    }

    print("\n═══ Ablation Study Results ═══")
    for name, data in results.items():
        print(f"\n{name}:")
        print(f"  Time: {data.get('time_ms', 0):.0f}ms")
        print(f"  Confidence: {data.get('confidence', 'N/A')}")
        print(f"  Text preview: {data.get('text', '')[:100]}")

    return results

